# Dependencies
node_modules

# Next.js
.next

# Turborepo
.turbo

# Prisma generated — gitignored by default,
# but the modern `prisma-client` generator output under
# `packages/db/src/generated/` IS committed (so consumers skip a regen step
# on fresh checkouts). The drift check (pnpm --filter @contractor-ops/db
# run db:check-drift) keeps it in sync with the schema.
generated
!/packages/db/src/generated
!/packages/db/src/generated/**

# Environment
.env
.env.local
.env.*.local

# Build output
dist
out
apps/*/out

# Test coverage
coverage

# Brain vault (commit wiki; ignore hook noise + generated indexes)
.planning/brain/.vault-meta/
.planning/brain/graphify-out/

# Graphify AST graph (~20MB) — regenerate after code refactors:
#   graphify update . --no-cluster --force && cp graphify-out/graph.json .planning/graphs/graph.json
.planning/graphs/graph.json
graphify-out/

# Playwright (auth state, reports, test results)
apps/web/e2e/perf/.auth/
apps/web/e2e/perf/results/
apps/web/e2e/functional/.auth/
apps/web/playwright-report/
test-results

# TypeScript
*.tsbuildinfo

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# GSD graphify local venv (bootstrap tooling)
.planning/.venv-graphify/

# Claude Code agent scratch worktrees — never commit
.claude/worktrees/
.claude/hooks/.state/
.dev-logs/

# QA walk local runs (screenshots, manifests)
goals/qa-walk-and-fix/findings/**
!goals/qa-walk-and-fix/findings/.gitkeep

# Post-migration parity audit scratch — never commit
.audit-scratch/
.restoration-scratch/

# Security red-team harness — local-only attack scripts, load profiles, findings.
# Never committed: contains live exploit scripts + may capture sensitive responses.
# Committed regression coverage lives in *.security.test.ts under each package's __tests__.
security/harness/
