# Dev observability stack envs — copy to .env (or .env.observability if you
# load it separately) and source before `docker compose -f
# docker-compose.observability.yml up -d`.
#
# Production must NOT set these — GlitchTip + Loki are dev replacements for
# the prod Sentry SaaS + Axiom Cloud and only listen on localhost.

# ── GlitchTip (Sentry-compatible) ──────────────────────────────────────
# Postgres credentials — keep them random per machine; do not reuse in prod.
GLITCHTIP_DB_USER=glitchtip
GLITCHTIP_DB_PASSWORD=change-me-locally
GLITCHTIP_DB_NAME=glitchtip

# Django secret. `openssl rand -hex 50` then drop the hex in here. Dev only;
# rotating it just invalidates the on-disk session cookie.
GLITCHTIP_SECRET_KEY=replace-with-openssl-rand-hex-50

# Public URL — must match what the SDK sees as DSN host. Keep at
# http://localhost:8000 unless you are routing through a tunnel.
GLITCHTIP_DOMAIN=http://localhost:8000

# After first signup on http://localhost:8000 → create org → create project →
# copy the generated DSN here.
#
# Example DSN shape (the actual key after signup will differ):
#   SENTRY_DSN=http://abc123@localhost:8000/1
#   VITE_SENTRY_DSN=http://abc123@localhost:8000/1
#
# Set SENTRY_DEV=true so the in-app dev guard (apps/api/src/lib/sentry.ts:24)
# lets the events flow into GlitchTip instead of dropping them.
SENTRY_DEV=true

# ── Loki ──────────────────────────────────────────────────────────────
# Pino transport ships logs to this URL when present. Unset in prod.
LOKI_URL=http://localhost:3100

# ── Grafana ───────────────────────────────────────────────────────────
# Default UI at http://localhost:3001 — anonymous Admin role is on by
# default in dev, no password required. Login form is still available for
# named users if you want a token.
