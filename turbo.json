{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck:fast": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "inputs": ["prisma/schema/**/*.prisma", "package.json"],
      "outputs": ["src/generated/prisma/client/**"]
    },
    "db:check-drift": {
      "inputs": ["prisma/schema/**/*.prisma", "src/generated/prisma/client/**", "package.json"],
      "outputs": []
    },
    "db:migrate:dev": {
      "cache": false
    }
  }
}
