{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "i18n:types"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["i18n:types"]
    },
    "lint": {
      "dependsOn": ["^build", "i18n:types"]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["^build", "i18n:types"]
    },
    "typecheck": {
      "dependsOn": ["^build", "i18n:types"],
      "outputs": []
    },
    "typecheck:fast": {
      "dependsOn": ["^build", "i18n:types"],
      "outputs": []
    },
    "i18n:types": {
      "inputs": ["../../scripts/generate-i18n-types.ts", "messages/en.json"],
      "outputs": ["src/generated/i18n/**"]
    },
    "test": {
      "dependsOn": ["^build", "i18n:types"]
    },
    "db:generate": {
      "inputs": ["prisma/schema/**/*.prisma", "package.json"],
      "outputs": ["src/generated/prisma/client/**"]
    },
    "db:check-drift": {
      "inputs": ["prisma/schema/**/*.prisma", "src/generated/prisma/client/**", "package.json"],
      "outputs": []
    },
    "db:check-migration-drift": {
      "inputs": ["prisma/schema/**/*.prisma", "prisma/schema/migrations/**", "package.json"],
      "outputs": [],
      "cache": false
    },
    "db:migrate:dev": {
      "cache": false
    }
  }
}
