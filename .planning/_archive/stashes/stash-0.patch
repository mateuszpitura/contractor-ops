+describe('r2 putObjectString', () => {
+  beforeEach(() => {
+    putObjectCalls.length = 0;
+    mockState.sendImpl = null;
+  });
+
+  it('calls S3 client.send with PutObjectCommand containing correct params', async () => {
+    await putObjectString({
+      key: 'orgs/o1/documents/inv-1.xml',
+      body: '<Invoice/>',
+      contentType: 'application/xml',
+    });
+
+    expect(putObjectCalls).toHaveLength(1);
+    const call = putObjectCalls.at(0);
+    expect(call?.input).toMatchObject({
+      Bucket: 'bucket-test',
+      Key: 'orgs/o1/documents/inv-1.xml',
+      Body: '<Invoice/>',
+      ContentType: 'application/xml',
+    });
+  });
+
+  it('passes the string body directly as the Body parameter', async () => {
+    const xmlPayload = '<?xml version="1.0"?><root><item>hello</item></root>';
+    await putObjectString({
+      key: 'orgs/o2/documents/data.xml',
+      body: xmlPayload,
+      contentType: 'text/xml',
+    });
+
+    const call = putObjectCalls.at(0);
+    expect(call?.input.Body).toBe(xmlPayload);
+    expect(typeof call?.input.Body).toBe('string');
+  });
+
+  it('propagates S3 errors', async () => {
+    const s3Error = new Error('S3 PutObject failed');
+    mockState.sendImpl = () => {
+      throw s3Error;
+    };
+
+    await expect(
+      putObjectString({ key: 'k', body: 'x', contentType: 'text/plain' }),
+    ).rejects.toThrow('S3 PutObject failed');
+  });
