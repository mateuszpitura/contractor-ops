+    mockState.sendImpl = null;
+  });
+
+  it('returns string content from body.transformToString', async () => {
+    const xml = '<Invoice><Total>100</Total></Invoice>';
+    mockState.sendImpl = () => ({
+      Body: { transformToString: async (_enc?: string) => xml },
+    });
+
+    const result = await getObjectAsString('orgs/o1/documents/inv.xml');
+    expect(result).toBe(xml);
+  });
+
+  it('throws when response Body is undefined', async () => {
+    mockState.sendImpl = () => ({});
+
+    await expect(getObjectAsString('orgs/o1/missing.xml')).rejects.toThrow(
+      /empty \/ unreadable body/,
+    );
+  });
+
+  it('throws when response Body lacks transformToString method', async () => {
