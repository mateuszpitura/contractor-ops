+function XhrSuccess() {
+  return class {
+    status = 200;
+    upload = {
+      onprogress: null as ((e: ProgressEvent) => void) | null,
+    };
+    onload: (() => void) | null = null;
+    onerror: (() => void) | null = null;
+    open = vi.fn();
+    setRequestHeader = vi.fn();
+    send = vi.fn(() => {
+      queueMicrotask(() => {
+        this.upload.onprogress?.({
+          lengthComputable: true,
+          loaded: 100,
+          total: 100,
+        } as ProgressEvent);
+        queueMicrotask(() => {
+          this.onload?.();
+        });
+      });
+    });
+  };
+}
+
+function XhrPutForbidden() {
+  return class {
+    status = 403;
+    upload = {
+      onprogress: null as ((e: ProgressEvent) => void) | null,
+    };
+    onload: (() => void) | null = null;
+    onerror: (() => void) | null = null;
+    open = vi.fn();
+    setRequestHeader = vi.fn();
+    send = vi.fn(() => {
+      queueMicrotask(() => {
+        this.onload?.();
+      });
+    });
+  };
+}
+
+function XhrPutNetworkError() {
+  return class {
+    status = 0;
+    upload = {
+      onprogress: null as ((e: ProgressEvent) => void) | null,
+    };
+    onload: (() => void) | null = null;
+    onerror: (() => void) | null = null;
+    open = vi.fn();
+    setRequestHeader = vi.fn();
+    send = vi.fn(() => {
+      queueMicrotask(() => {
+        this.onerror?.();
+      });
+    });
+  };
+}
+
+function XhrPutForbiddenThenSuccess() {
+  let attempt = 0;
+  return class {
+    status = 200;
+    upload = {
+      onprogress: null as ((e: ProgressEvent) => void) | null,
+    };
+    onload: (() => void) | null = null;
+    onerror: (() => void) | null = null;
+    open = vi.fn();
+    setRequestHeader = vi.fn();
+    send = vi.fn(function (this: {
+      status: number;
+      upload: { onprogress: ((e: ProgressEvent) => void) | null };
+      onload: (() => void) | null;
+    }) {
+      const xhr = this;
+      const n = ++attempt;
+      queueMicrotask(() => {
+        if (n === 1) {
+          xhr.status = 403;
+          xhr.onload?.();
+        } else {
+          xhr.status = 200;
+          xhr.upload.onprogress?.({
+            lengthComputable: true,
+            loaded: 100,
+            total: 100,
+          } as ProgressEvent);
+          queueMicrotask(() => {
+            xhr.onload?.();
+          });
+        }
+      });
+    });
+  };
+}
