    "@contractor-ops/public-api": {
      "path": "apps/public-api",
      "depends_on": [
        "@contractor-ops/api",
        "@contractor-ops/db",
        "@contractor-ops/feature-flags",
        "@contractor-ops/logger"
      ],
      "notes": "REST routes call createPublicCaller; logic lives in packages/api/src/routers/public-api/"
