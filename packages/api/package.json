{
  "name": "@contractor-ops/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./services/slack-client": {
      "types": "./src/services/slack-client.ts",
      "import": "./src/services/slack-client.ts",
      "default": "./src/services/slack-client.ts"
    },
    "./services/approval-engine": {
      "types": "./src/services/approval-engine.ts",
      "import": "./src/services/approval-engine.ts",
      "default": "./src/services/approval-engine.ts"
    },
    "./services/notification-service": {
      "types": "./src/services/notification-service.ts",
      "import": "./src/services/notification-service.ts",
      "default": "./src/services/notification-service.ts"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@contractor-ops/auth": "workspace:*",
    "@contractor-ops/db": "workspace:*",
    "@contractor-ops/validators": "workspace:*",
    "@react-email/components": "^1.0.10",
    "@slack/web-api": "^7.15.0",
    "@trpc/server": "^11.0.0",
    "bir1": "^4.1.1",
    "clamscan": "^2.4.0",
    "file-type": "^21.3.3",
    "react": "^19.0.0",
    "resend": "^4.8.0",
    "superjson": "^2.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.5.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
