{
  "name": "@contractor-ops/integrations",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./services/credential-service": {
      "types": "./dist/services/credential-service.d.ts",
      "import": "./dist/services/credential-service.js",
      "default": "./dist/services/credential-service.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js",
      "default": "./dist/registry.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./services/qstash-client": {
      "types": "./dist/services/qstash-client.d.ts",
      "import": "./dist/services/qstash-client.js",
      "default": "./dist/services/qstash-client.js"
    },
    "./services/webhook-dispatcher": {
      "types": "./dist/services/webhook-dispatcher.d.ts",
      "import": "./dist/services/webhook-dispatcher.js",
      "default": "./dist/services/webhook-dispatcher.js"
    },
    "./adapters/register-all": {
      "types": "./dist/adapters/register-all.d.ts",
      "import": "./dist/adapters/register-all.js",
      "default": "./dist/adapters/register-all.js"
    },
    "./services/esign-service": {
      "types": "./dist/services/esign-service.d.ts",
      "import": "./dist/services/esign-service.js",
      "default": "./dist/services/esign-service.js"
    },
    "./services/ocr-service": {
      "types": "./dist/services/ocr-service.d.ts",
      "import": "./dist/services/ocr-service.js",
      "default": "./dist/services/ocr-service.js"
    },
    "./types/ocr": {
      "types": "./dist/types/ocr.d.ts",
      "import": "./dist/types/ocr.js",
      "default": "./dist/types/ocr.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@contractor-ops/db": "workspace:*",
    "@contractor-ops/validators": "workspace:^",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.34.0",
    "docusign-esign": "8.6.0",
    "fast-xml-parser": "^5.5.9",
    "resend": "^6.9.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
