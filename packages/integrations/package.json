{
  "name": "@contractor-ops/integrations",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./services/credential-service": {
      "types": "./src/services/credential-service.ts",
      "import": "./src/services/credential-service.ts",
      "default": "./src/services/credential-service.ts"
    },
    "./registry": {
      "types": "./src/registry.ts",
      "import": "./src/registry.ts",
      "default": "./src/registry.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@contractor-ops/db": "workspace:*",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.34.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
