# @contractor-ops/integrations — provider credential encryption keys
#
# Credential blobs are encrypted at rest with AES-256-GCM using a per-provider
# key resolved dynamically by `credential-service.ts getProviderEncryptionKey`
# from `${PROVIDER_SLUG_UPPER}_ENCRYPTION_KEY`. There is no static Zod env schema
# in this package by design — the key set is keyed on the provider slug, not a
# fixed list. Each value is a hex-encoded 32-byte key.
#
# All keys below are OPTIONAL for the GA floor: the programmatic-ACH and Plaid
# paths ship as deterministic mocks behind their seams and need ZERO credentials.
# These are required only when the live paths are activated (flag flip + creds).

# --- Programmatic ACH (Modern Treasury) — live path only, flag-dark ---
# Encrypts the Modern Treasury credential blob (Org-ID + API-key).
MODERN_TREASURY_ENCRYPTION_KEY=
# Optional live API credentials (stored encrypted; not read as raw env in app code).
# MODERN_TREASURY_ORG_ID=
# MODERN_TREASURY_API_KEY=

# --- Plaid Identity verification — live path only, flag-dark ---
# Encrypts the Plaid credential blob (client id + secret).
PLAID_ENCRYPTION_KEY=
# Optional live API credentials (stored encrypted; not read as raw env in app code).
# PLAID_CLIENT_ID=
# PLAID_SECRET=
