{
  "name": "@contractor-ops/einvoice",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./orchestration": {
      "types": "./src/orchestration/index.ts",
      "import": "./src/orchestration/index.ts",
      "default": "./src/orchestration/index.ts"
    },
    "./compliance": {
      "types": "./dist/types/compliance.d.ts",
      "import": "./dist/types/compliance.js",
      "default": "./dist/types/compliance.js"
    },
    "./zatca/schemas": {
      "types": "./dist/profiles/zatca/schemas.d.ts",
      "import": "./dist/profiles/zatca/schemas.js",
      "default": "./dist/profiles/zatca/schemas.js"
    },
    "./zatca/types": {
      "types": "./dist/profiles/zatca/types.d.ts",
      "import": "./dist/profiles/zatca/types.js",
      "default": "./dist/profiles/zatca/types.js"
    }
  },
  "scripts": {
    "build": "tsc && node ./scripts/copy-zugferd-assets.mjs",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit"
  },
  "dependencies": {
    "@contractor-ops/gov-api": "workspace:*",
    "@contractor-ops/logger": "workspace:*",
    "@react-pdf/renderer": "^4.5.1",
    "react": "^19.2.6",
    "fast-xml-parser": "^5.7.3",
    "libxmljs2": "^0.37.0",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "saxon-js": "^2.7.0",
    "xml-crypto": "^6.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.5",
    "@xmldom/xmldom": "^0.9.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "xslt3": "^2.7.0"
  }
}
