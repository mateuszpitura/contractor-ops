{
  "name": "@contractor-ops/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "prisma/schema", "generated"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./generated/prisma/client": {
      "types": "./generated/prisma/client/index.d.ts",
      "default": "./generated/prisma/client/index.js"
    },
    "./generated/prisma/client/runtime/client": {
      "types": "./generated/prisma/client/runtime/client.d.ts",
      "default": "./generated/prisma/client/runtime/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status"
  },
  "dependencies": {
    "prisma": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/adapter-neon": "^7.5.0",
    "@neondatabase/serverless": "^1.0.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
