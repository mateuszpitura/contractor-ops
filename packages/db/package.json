{
  "name": "@contractor-ops/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prisma/schema"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./generated/prisma/client": {
      "types": "./dist/generated/prisma/client/client.d.ts",
      "default": "./dist/generated/prisma/client/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push:all": "tsx scripts/push-all-regions.ts",
    "db:check-drift": "tsx scripts/check-generated-drift.ts",
    "db:seed:dev": "tsx scripts/seed-dev.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit"
  },
  "dependencies": {
    "@contractor-ops/compliance-policy": "workspace:*",
    "@contractor-ops/logger": "workspace:*",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "better-auth": "^1.6.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
