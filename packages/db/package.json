{
  "name": "@contractor-ops/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prisma/schema",
    "generated"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./generated/prisma/client": {
      "types": "./generated/prisma/client/index.d.ts",
      "default": "./generated/prisma/client/index.js"
    },
    "./generated/prisma/client/runtime/client": {
      "types": "./generated/prisma/client/runtime/client.d.ts",
      "default": "./generated/prisma/client/runtime/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push:all": "tsx scripts/push-all-regions.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit"
  },
  "dependencies": {
    "@contractor-ops/compliance-policy": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.1",
    "pino": "^9.14.0",
    "prisma": "^7.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
