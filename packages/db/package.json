{
  "name": "@contractor-ops/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prisma/schema"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./generated/prisma/client": {
      "types": "./dist/generated/prisma/client/client.d.ts",
      "default": "./dist/generated/prisma/client/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:all": "tsx scripts/migrate-all-regions.ts",
    "db:check-drift": "tsx scripts/check-generated-drift.ts",
    "db:audit-enum-casing": "tsx scripts/audit-enum-casing.ts",
    "db:seed:dev": "PRISMA_SLOW_QUERY_THRESHOLD_MS=999999 tsx scripts/seed-dev.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit"
  },
  "dependencies": {
    "@contractor-ops/compliance-policy": "workspace:*",
    "@contractor-ops/logger": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.13.0",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.4.2",
    "opossum": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/cli-progress": "^3.11.6",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.9",
    "cli-progress": "^3.12.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
