// PaymentRun, PaymentRunItem, PaymentExport

model PaymentRun {
  id               String               @id @default(cuid())
  organizationId   String
  runNumber        String?
  name             String?
  status           PaymentRunStatus     @default(DRAFT)
  currency         String?              @db.Char(3)
  createdByUserId  String
  approvedByUserId String?
  totalMinor       Int                  @default(0)
  invoiceCount     Int                  @default(0)
  exportFormat     PaymentExportFormat?
  exportedAt       DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("PaymentRunCreator", fields: [createdByUserId], references: [id])
  approvedBy   User?        @relation("PaymentRunApprover", fields: [approvedByUserId], references: [id])

  items                  PaymentRunItem[]
  exports                PaymentExport[]
  complianceChecks       PaymentRunComplianceCheck[] // Phase 72 D-16
  achReturnLedgerEntries AchReturnLedgerEntry[]

  @@unique([organizationId, runNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model PaymentRunItem {
  id                 String               @id @default(cuid())
  organizationId     String
  paymentRunId       String
  invoiceId          String
  contractorId       String
  billingProfileId   String?
  amountMinor        Int
  currency           String               @db.Char(3)
  status             PaymentRunItemStatus @default(PENDING)
  paymentReference   String?
  markedPaidAt       DateTime?
  failureReason      String?
  whtAmountMinor     Int?
  whtRate            Decimal?             @db.Decimal(5, 2)
  whtTreatyApplied   Boolean?
  whtTreatyReference String?              @db.VarChar(100)
  whtServiceType     String?              @db.VarChar(50)
  grossAmountMinor   Int? // Original amount before WHT deduction
  // FX provenance for a cross-currency settled payout: the rate (and its source
  // date) actually applied at settlement time. Nullable — populated only for
  // converted payouts by the settlement path; backfill-safe for existing rows.
  settlementRate     Decimal?             @db.Decimal(18, 8)
  settlementRateDate DateTime?            @db.Date
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  organization   Organization              @relation(fields: [organizationId], references: [id])
  paymentRun     PaymentRun                @relation(fields: [paymentRunId], references: [id])
  invoice        Invoice                   @relation(fields: [invoiceId], references: [id])
  contractor     Contractor                @relation(fields: [contractorId], references: [id])
  billingProfile ContractorBillingProfile? @relation(fields: [billingProfileId], references: [id])

  invoicePayments        InvoicePayment[]
  skontoApplication      SkontoApplication?
  achReturnLedgerEntries AchReturnLedgerEntry[]
  whtCertificate         WhtCertificate?

  @@unique([paymentRunId, invoiceId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, invoiceId])
}

model PaymentExport {
  id                String              @id @default(cuid())
  organizationId    String
  paymentRunId      String
  documentId        String?
  format            PaymentExportFormat
  status            ExportStatus        @default(GENERATED)
  generatedByUserId String
  generatedAt       DateTime            @default(now())
  downloadedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  paymentRun   PaymentRun   @relation(fields: [paymentRunId], references: [id])
  document     Document?    @relation(fields: [documentId], references: [id])
  generatedBy  User         @relation(fields: [generatedByUserId], references: [id])

  complianceChecks PaymentRunComplianceCheck[] // Phase 72 D-16

  // One export row per run — the DB backstop for the atomic lockAndExport guard.
  @@unique([paymentRunId])
  @@index([organizationId])
  @@index([organizationId, paymentRunId])
}

// Phase 72 D-16 — One row per (PaymentRun × Contractor × export attempt).
// snapshotJson is a frozen full copy of the contractor's BLOCKING-severity
// ContractorComplianceItem rows at the moment of export — replay-ready audit.
// FAIL-verdict rows have paymentExportId = null (export aborted) and are written
// in a separate small tx after the parent tx rolls back (D-19). Append-only (no updatedAt).
model PaymentRunComplianceCheck {
  id                   String             @id @default(cuid())
  organizationId       String
  paymentRunId         String
  paymentExportId      String?
  contractorId         String
  snapshottedAt        DateTime           @default(now())
  snapshotJson         Json
  eligibilityVerdict   EligibilityVerdict
  failureReasons       Json?
  policyRuleSetVersion String
  createdAt            DateTime           @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id])
  paymentRun    PaymentRun     @relation(fields: [paymentRunId], references: [id])
  paymentExport PaymentExport? @relation(fields: [paymentExportId], references: [id], onDelete: SetNull)
  contractor    Contractor     @relation(fields: [contractorId], references: [id])

  // PASS-row dedup guard: a given contractor can appear at most once per export.
  // paymentExportId is null for FAIL rows (export aborted); Postgres treats NULL
  // as non-equal in unique constraints so multiple FAIL rows are allowed —
  // only PASS rows (non-null paymentExportId) are constrained to one per contractor.
  @@unique([paymentExportId, contractorId])
  @@index([organizationId])
  @@index([paymentRunId])
  @@index([contractorId, snapshottedAt(sort: Desc)])
  @@index([paymentExportId])
}

// --- Enums ---

enum PaymentStatus {
  NOT_READY
  READY
  IN_RUN
  PARTIALLY_PAID
  PAID
  FAILED
}

enum PaymentRunStatus {
  DRAFT
  LOCKED
  EXPORTED
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentRunItemStatus {
  PENDING
  EXPORTED
  PAID
  FAILED
  SKIPPED
}

enum PaymentExportFormat {
  CSV
  BANK_FILE
  SEPA_XML
  SWIFT_XML
  MT940
  XML
  API_PUSH
  BACS_STD18
  ACH_NACHA
  FEDWIRE
}

enum ExportStatus {
  GENERATED
  DOWNLOADED
  FAILED
}

// Phase 72 D-16 — Verdict enum for the atomic compliance audit row.
enum EligibilityVerdict {
  PASS
  FAIL
}

// NACHA return-file entry kind: a Return (addenda type 99, R-codes) reverses a
// payout; a Notification-of-Change (addenda type 98, C-codes) is advisory only.
enum AchReturnEntryType {
  RETURN
  NOTIFICATION_OF_CHANGE
}

// Entry-level ledger of processed ACH return-file entries — the idempotency
// backstop for return uploads. One row per distinct entry within a run
// (traceNumber + returnCode); a re-uploaded or redelivered file short-circuits on
// the unique constraint instead of re-flipping an item or duplicating advisory
// audit rows. individualId/amountMinor/addendaInfo capture the parsed entry;
// fileSha256 records which upload first applied it.
model AchReturnLedgerEntry {
  id               String             @id @default(cuid())
  organizationId   String
  paymentRunId     String
  paymentRunItemId String?
  entryType        AchReturnEntryType @default(RETURN)
  traceNumber      String
  returnCode       String             @db.VarChar(8)
  individualId     String?
  amountMinor      Int?
  addendaInfo      String?
  fileSha256       String?            @db.VarChar(64)
  appliedAt        DateTime?
  createdAt        DateTime           @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id])
  paymentRun     PaymentRun      @relation(fields: [paymentRunId], references: [id])
  paymentRunItem PaymentRunItem? @relation(fields: [paymentRunItemId], references: [id])

  @@unique([paymentRunId, traceNumber, returnCode], map: "ach_return_entry_run_trace_code_uniq")
  @@index([organizationId])
  @@index([paymentRunId])
}
