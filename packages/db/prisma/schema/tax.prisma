// TaxRate — country-specific VAT/tax rates (read-only, seed data managed)
// WithholdingTaxRate — Saudi WHT rates with DTA treaty data

model TaxRate {
  id              String    @id @default(cuid())
  countryCode     String    @db.Char(2)
  code            String    @db.VarChar(10)
  description     String    @db.VarChar(100)
  ratePercent     Decimal   @db.Decimal(5, 2)
  isDefault       Boolean   @default(false)
  isReverseCharge Boolean   @default(false)
  isExempt        Boolean   @default(false)
  effectiveFrom   DateTime  @db.Date
  effectiveTo     DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([countryCode, code, effectiveFrom])
  @@index([countryCode])
  @@index([countryCode, effectiveFrom, effectiveTo])
}

model WithholdingTaxRate {
  id                  String    @id @default(cuid())
  sourceCountry       String    @db.Char(2)
  contractorResidency String    @db.Char(2)
  // Income-type axis; for US source rows this carries 'business_profits'.
  serviceType         String    @db.VarChar(50)
  standardRate        Decimal   @db.Decimal(5, 2)
  treatyRate          Decimal?  @db.Decimal(5, 2)
  treatyReference     String?   @db.VarChar(100)
  // Structured treaty article (e.g. "Article 7") so a W-8BEN line-10 / W-8BEN-E
  // line-15 claim can be auto-populated; treatyReference stays free-text prose.
  treatyArticle       String?   @db.VarChar(40)
  effectiveFrom       DateTime  @db.Date
  effectiveTo         DateTime? @db.Date
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([sourceCountry, contractorResidency, serviceType, effectiveFrom])
  @@index([sourceCountry])
  @@index([sourceCountry, contractorResidency])
}

model WhtCertificate {
  id                String   @id @default(cuid())
  organizationId    String
  paymentRunItemId  String
  certificateNumber String   @db.VarChar(50)
  documentId        String?
  grossAmountMinor  Int
  whtRate           Decimal  @db.Decimal(5, 2)
  whtAmountMinor    Int
  netAmountMinor    Int
  currency          String   @db.Char(3)
  contractorName    String
  contractorTaxId   String?
  contractorCountry String   @db.Char(2)
  treatyApplied     Boolean  @default(false)
  treatyReference   String?  @db.VarChar(100)
  paymentDate       DateTime @db.Date
  generatedAt       DateTime @default(now())
  generatedByUserId String

  @@unique([organizationId, certificateNumber])
  @@index([organizationId])
  @@index([organizationId, paymentRunItemId])
}

// US tax-status form (W-9 / W-8BEN / W-8BEN-E) intake.
// Immutable record-of-record: a signed form is never mutated — re-certification
// inserts a new row and marks the prior one SUPERSEDED via the supersede chain.

enum TaxFormType {
  W9
  W8BEN
  W8BENE
}

enum TaxFormStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
}

model TaxFormSubmission {
  id                  String        @id @default(cuid())
  organizationId      String
  contractorId        String
  formType            TaxFormType
  status              TaxFormStatus @default(DRAFT)
  // Captured form fields + ESIGN attestation (typed name, timestamp, IP, userId).
  // Never holds a full SSN — only last-4 plus an encrypted-column reference.
  snapshotJson        Json
  // Resolved treaty claim mirrored from WithholdingTaxRate at sign time.
  treatyArticle       String?       @db.VarChar(40)
  treatyRate          Decimal?      @db.Decimal(5, 2)
  contractorResidency String?       @db.Char(2)
  signerName          String?
  signedAt            DateTime?
  // W-8BEN/W-8BEN-E claims expire ~3 years after signing.
  expiresAt           DateTime?
  supersededById      String?       @unique
  createdAt           DateTime      @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id])
  contractor   Contractor         @relation(fields: [contractorId], references: [id])
  supersededBy TaxFormSubmission? @relation("Supersede", fields: [supersededById], references: [id])
  supersedes   TaxFormSubmission? @relation("Supersede")

  @@index([organizationId, contractorId, formType, status])
  @@index([organizationId, status, expiresAt])
}

// 1099-NEC year-end information return + IRS IRIS e-file records.
//
// Form1099Nec is an immutable record-of-record: a filed return is never mutated;
// a CORRECTED return inserts a new row and marks the prior one SUPERSEDED via the
// supersede chain (mirrors TaxFormSubmission). The snapshot keeps last-4 TIN only,
// never a full SSN. Both threshold and per-state CFSF rules live in config tables
// keyed by tax year / state — never hardcoded constants — because the federal
// threshold rose from $600 (TY2025) to $2,000 (TY2026, OBBBA) and the Combined
// Federal/State Filing participant list drifts year to year.

enum Form1099Status {
  DRAFT
  ACTIVE
  SUPERSEDED
}

// The six acknowledgement states the IRS IRIS A2A and manual-upload ack files report.
enum IrisAckStatus {
  ACCEPTED
  REJECTED
  PROCESSING
  PARTIALLY_ACCEPTED
  ACCEPTED_WITH_ERRORS
  NOT_FOUND
}

model Form1099Nec {
  id                         String         @id @default(cuid())
  organizationId             String
  // Aggregation axis: box-1 comp is summed per recipient per payer-org. For a
  // self-org filing this equals organizationId; it is carried explicitly so a
  // future agent-org-filing-on-behalf-of-payer split is non-breaking.
  payerOrgId                 String
  recipientId                String
  taxYear                    Int
  status                     Form1099Status @default(DRAFT)
  // Box amounts in minor units (USD cents). Box 4 is recorded backup
  // withholding; the actual payout reduction is enforced in a later phase.
  box1AmountMinor            Int
  box4BackupWithholdingMinor Int            @default(0)
  currency                   String         @default("USD") @db.Char(3)
  // Combined Federal/State Filing state code emitted in the IRIS B-record so the
  // IRS auto-forwards to participating states.
  cfsfStateCode              String?        @db.Char(2)
  corrected                  Boolean        @default(false)
  // Immutable captured figures (record-of-record); holds last-4 TIN only, never a
  // full SSN — mirror TaxFormSubmission.snapshotJson.
  snapshotJson               Json
  pdfArchiveKey              String?
  supersededById             String?        @unique
  // Required for the data-purge soft-delete chokepoint that enforces IRS retention.
  deletedAt                  DateTime?
  createdAt                  DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  recipient    Contractor   @relation(fields: [recipientId], references: [id])
  supersededBy Form1099Nec? @relation("Form1099Supersede", fields: [supersededById], references: [id])
  supersedes   Form1099Nec? @relation("Form1099Supersede")

  @@index([organizationId, payerOrgId, recipientId, taxYear, status])
  @@index([organizationId, taxYear, status])
}

// Append-only record of one IRIS transmission, capturing the schema VersionNum /
// VersionDt the file was built against (the IRS revs the schema per tax year).
model IrisSubmission {
  id                String         @id @default(cuid())
  organizationId    String
  taxYear           Int
  schemaVersionNum  String
  schemaVersionDt   String
  // manual | iris-a2a | vendor
  transmitMethod    String
  // Carries the IRS receipt id being replaced, for a replacement transmission.
  originalReceiptId String?
  status            IrisAckStatus?
  xmlArchiveKey     String?
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  acks         IrisAck[]

  @@index([organizationId, taxYear])
}

// Append-only parsed acknowledgement. The same parser consumes both the manual
// uploaded ack file and the A2A poll result.
model IrisAck {
  id                   String        @id @default(cuid())
  organizationId       String
  submissionId         String
  status               IrisAckStatus
  // The IRIS Error Information Group, preserved structurally for rejection detail.
  errorInformationJson Json?
  receiptId            String?
  parsedAt             DateTime      @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id])
  submission   IrisSubmission @relation(fields: [submissionId], references: [id])

  @@index([organizationId, submissionId])
}

// Tax-year-keyed 1099-NEC reporting threshold. NEVER a constant: $600 TY2025,
// $2,000 TY2026 (OBBBA), inflation-indexed thereafter.
model Tax1099Threshold {
  id                 String  @id @default(cuid())
  taxYear            Int     @unique
  box1ThresholdMinor Int
  currency           String  @default("USD") @db.Char(3)
  note               String?
}

// Per-state Combined Federal/State Filing config. Drives whether a recipient's
// state is auto-forwarded by the IRS (CFSF) or requires a separate direct filing.
model StateFilingConfig {
  id                       String  @id @default(cuid())
  stateCode                String  @db.Char(2)
  taxYear                  Int
  cfsfParticipant          Boolean
  requiresDirectFiling     Boolean
  filingThresholdMinor     Int?
  stateWithholdingBoxRules Json?
  note                     String?

  @@unique([stateCode, taxYear])
}

// ---------------------------------------------------------------------------
// Phase 57 — Tax-ID validation audit trail (HMRC VAT + VIES USt-IdNr)
// D-04: append-only audit log of every HMRC/VIES call for compliance evidence.
// ---------------------------------------------------------------------------

enum TaxIdType {
  GB_VAT
  DE_USTIDNR
}

enum ValidationStatus {
  VALID
  INVALID
  STALE
  UNAVAILABLE
}

model TaxIdValidation {
  id              String           @id @default(cuid())
  organizationId  String
  contractorId    String
  taxIdType       TaxIdType
  taxIdValue      String           @db.VarChar(20)
  apiProvider     String           @db.VarChar(20)
  requestedAt     DateTime         @default(now())
  validFrom       DateTime?
  validTo         DateTime?
  confirmationRef String?          @db.VarChar(50)
  responseStatus  ValidationStatus
  responseBody    Json
  errorMessage    String?

  organization Organization @relation(fields: [organizationId], references: [id])
  contractor   Contractor   @relation(fields: [contractorId], references: [id])

  @@index([contractorId, taxIdType, requestedAt(sort: Desc)])
  @@index([organizationId, requestedAt])
  @@index([organizationId, responseStatus])
}
