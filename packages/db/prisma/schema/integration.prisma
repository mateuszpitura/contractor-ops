// IntegrationConnection, IntegrationSyncLog, ExternalLink, WebhookDelivery

model IntegrationConnection {
  id                String              @id @default(cuid())
  organizationId    String
  provider          IntegrationProvider
  status            IntegrationStatus   @default(DISCONNECTED)
  displayName       String?
  configJson        Json?
  scopeCapabilities Json? // Phase 70 D-13 — typed via packages/db/src/types/scope-capabilities.ts
  credentialsRef    String
  connectedByUserId String
  userId            String? // null = org-level, set = per-user personal connection (D-12, D-14)
  connectedAt       DateTime            @default(now())
  lastSyncAt        DateTime?
  lastSuccessAt     DateTime?
  lastErrorAt       DateTime?
  lastErrorMessage  String?
  tokenExpiresAt    DateTime? // When access token expires (for proactive refresh)
  refreshLockedAt   DateTime? // Distributed lock timestamp for refresh race condition prevention
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  connectedBy  User         @relation(fields: [connectedByUserId], references: [id])
  user         User?        @relation("personalConnections", fields: [userId], references: [id])

  externalLinks ExternalLink[]
  syncLogs      IntegrationSyncLog[]

  @@unique([organizationId, provider, userId], map: "integration_connection_org_provider_user_uniq")
  @@index([organizationId])
  @@index([organizationId, provider, status])
  @@index([organizationId, userId, provider])
  @@index([status, tokenExpiresAt])
}

model ExternalLink {
  id                      String     @id @default(cuid())
  organizationId          String
  integrationConnectionId String
  entityType              EntityType
  entityId                String
  externalType            String
  externalId              String
  externalUrl             String?
  metadataJson            Json?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  organization          Organization          @relation(fields: [organizationId], references: [id])
  integrationConnection IntegrationConnection @relation(fields: [integrationConnectionId], references: [id])

  @@index([organizationId])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, integrationConnectionId])
}

model IntegrationSyncLog {
  id                      String        @id @default(cuid())
  organizationId          String
  integrationConnectionId String
  direction               SyncDirection
  syncType                String
  entityType              EntityType?
  entityId                String?
  status                  SyncStatus
  requestPayloadJson      Json?
  responsePayloadJson     Json?
  errorMessage            String?
  startedAt               DateTime      @default(now())
  completedAt             DateTime?

  organization          Organization          @relation(fields: [organizationId], references: [id])
  integrationConnection IntegrationConnection @relation(fields: [integrationConnectionId], references: [id])

  @@index([organizationId])
  @@index([organizationId, integrationConnectionId, startedAt])
  @@index([organizationId, status])
}

model WebhookDelivery {
  id                      String                @id @default(cuid())
  organizationId          String
  integrationConnectionId String?
  provider                IntegrationProvider
  eventType               String
  deliveryStatus          WebhookDeliveryStatus @default(RECEIVED)
  signatureValid          Boolean?
  payloadJson             Json
  receivedAt              DateTime              @default(now())
  processedAt             DateTime?
  errorMessage            String?
  // F-INT-11 / F-INT-13: provider-supplied event ID (Stripe event.id,
  // Slack envelope_id, Resend svix-id, Storecove guid, etc.). Populated
  // by the ingress route from the verified payload BEFORE insert. Combined
  // with provider, this gives DB-enforced webhook dedup so two concurrent
  // ingress requests for the same upstream event collapse to one row
  // (catch P2002 and 200-OK the second).
  providerEventId         String?
  // F-INT-13 / P2-B: retry bookkeeping for the job-health reaper.
  //
  // - `attempts` increments on every reaper-triggered re-enqueue. The
  //   webhook _process consumer does NOT bump this on its own runtime,
  //   so legitimate slow handlers (Jira PR enrichment, e-sign ZIP
  //   generation can take 20+ min) are not penalised by their own
  //   duration.
  // - `nextAttemptAt` is the earliest moment the reaper may re-enqueue
  //   the row again (exponential backoff: 60s × 2^attempts, capped at 1h).
  //   Reads are paired with `deliveryStatus` so the reaper can find
  //   "stuck and ready to retry" rows in one index seek.
  // - `lastErrorAt` / `lastError` capture the most recent reaper failure
  //   reason so on-call has a fingerprint without scanning Sentry.
  //
  // The reaper marks a row FAILED only after `attempts >= MAX_ATTEMPTS`
  // (5 by default), so transient stalls no longer drop legitimate work.
  attempts                Int                   @default(0)
  nextAttemptAt           DateTime?
  lastErrorAt             DateTime?
  lastError               String?

  organization Organization @relation(fields: [organizationId], references: [id])

  // F-INT-13: dedup at the DB layer — partial index would be ideal here
  // (only when providerEventId is set) but Prisma's @@unique doesn't
  // support partial indexes, so callers must always populate
  // providerEventId or accept dup-row risk for that provider.
  @@unique([provider, providerEventId], map: "webhook_delivery_provider_event_uniq")
  @@index([organizationId])
  @@index([organizationId, provider, receivedAt])
  // F-INT-13 / P2-B: reaper lookup — find PROCESSING/RECEIVED rows whose
  // exponential backoff has elapsed in a single index seek.
  @@index([deliveryStatus, nextAttemptAt])
}

// --- Enums ---

enum IntegrationProvider {
  SLACK
  RESEND
  GOOGLE_WORKSPACE
  MICROSOFT_365
  JIRA
  DOCUSIGN
  AUTENTI
  KSEF
  ACCOUNTING
  OPEN_BANKING
  GITHUB
  GITLAB
  CLOCKIFY
  NOTION
  CONFLUENCE
  GOOGLE_CALENDAR
  OUTLOOK_CALENDAR
  LINEAR
  MICROSOFT_TEAMS
  PEPPOL
  ZATCA
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  REAUTH_REQUIRED
  PENDING_MAPPING
}

enum SyncDirection {
  INBOUND
  OUTBOUND
}

enum SyncStatus {
  STARTED
  SUCCESS
  FAILED
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}
