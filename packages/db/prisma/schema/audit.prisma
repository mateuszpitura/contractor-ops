// AuditLog
//
// NOTE: The OutboxEvent model + OutboxStatus enum live in outbox.prisma
// (P2-A, F-ASYNC-03). Previously a placeholder OutboxEvent existed here but
// was never read by any code; the new model in outbox.prisma extends it with
// attempts / nextAttemptAt / lastError / dispatchedAt / failedAt for the
// transactional outbox pattern.

model AuditLog {
  id             String     @id @default(cuid())
  organizationId String
  actorType      ActorType
  actorId        String?
  actorName      String?
  action         String
  resourceType   EntityType
  resourceId     String
  resourceName   String?
  oldValuesJson  Json?
  newValuesJson  Json?
  metadataJson   Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  // No updatedAt — audit logs are append-only. DB-enforced: the auditlog_insert
  // RLS policy allows only INSERT, a BEFORE UPDATE trigger rejects updates, and
  // DELETE is gated behind the transaction-local app.allow_audit_purge flag set
  // solely by the GDPR Right-to-Erasure path (migration 20260617000000).
  @@index([organizationId])
  @@index([organizationId, resourceType, resourceId, createdAt])
  @@index([organizationId, actorId, createdAt])
  @@index([organizationId, createdAt])
}

// --- Enums ---

enum ActorType {
  USER
  SYSTEM
  INTEGRATION
  API_KEY
  CONTRACTOR
  // Employee-portal self-service actor — an employee Worker acting on their own
  // records (leave request, document upload) or a line manager acting on a
  // direct report. Distinct from CONTRACTOR: a portal employee is never a
  // Contractor, and never a staff USER.
  EMPLOYEE
}
