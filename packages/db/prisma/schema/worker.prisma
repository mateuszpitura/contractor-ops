// Worker — the normalized identity root that Contractor (and a future Employee)
// link to via a sidecar 1:1 FK. The `workerType` discriminator (default
// CONTRACTOR) lives ONLY here: a Contractor row is inherently a contractor, so
// Contractor reads need no discriminator, while cross-type reads against Worker
// are scoped by the withWorkerTypeDefault extension (default CONTRACTOR unless
// the caller passes an explicit workerType).
//
// Tenant-owning: Worker carries `organizationId` and is deliberately absent
// from `globalModels` in tenant.ts, so it inherits withTenantScope (org scope
// is injected on every read/mutation).

enum WorkerType {
  CONTRACTOR
  EMPLOYEE
}

model Worker {
  id             String     @id @default(cuid())
  organizationId String
  workerType     WorkerType @default(CONTRACTOR)
  // Shared identity fields. Contractor-specific data stays on Contractor;
  // employee-specific data will live on a separate EmployeeProfile.
  displayName    String
  email          String?
  status         String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  organization     Organization      @relation(fields: [organizationId], references: [id])
  contractor       Contractor?
  // 1:1 sidecar carrying employee-specific data when workerType = EMPLOYEE.
  employeeProfile  EmployeeProfile?  @relation("EmployeeProfileWorker")
  // Employees whose reporting line points at this worker (the manager edge). A
  // manager is any worker some other EmployeeProfile.managerWorkerId targets.
  managedEmployees EmployeeProfile[] @relation("EmployeeManager")
  // 1:1 jurisdiction-correct personnel file ("akta osobowe") for employees.
  personnelFile    PersonnelFile?

  // Employee leave + statutory-time records (present when workerType = EMPLOYEE).
  leaveRequests       LeaveRequest[]
  leaveLedgerEntries  LeaveLedgerEntry[]
  leaveBalances       LeaveBalance[]
  employeeTimeRecords EmployeeTimeRecord[]
  // Employee on/offboarding runs + IdP deprovisioning runs keyed to this worker
  // (present when workerType = EMPLOYEE). Reciprocal of the nullable workerId FK
  // on WorkflowRun and DeprovisioningRun.
  workflowRuns        WorkflowRun[]
  deprovisioningRuns  DeprovisioningRun[]
  // Portal sessions authenticated as this worker (EMPLOYEE portal subject).
  portalSessions      PortalSession[]

  @@index([organizationId])
  @@index([organizationId, workerType])
}
