// Contractor, ContractorContact, ContractorBillingProfile,
// ContractorAssignment, ContractorTag, ContractorTagLink,
// ContractorComplianceItem, ComplianceRequirementTemplate

// Note: "search_vector" tsvector column exists in PostgreSQL (managed by migration)
// but is excluded from Prisma schema as it is GENERATED ALWAYS AS and Prisma
// does not support generated columns. Query via $queryRaw.

model Contractor {
  id                        String                   @id @default(cuid())
  organizationId            String
  type                      ContractorType
  legalName                 String
  displayName               String
  taxId                     String?
  vatId                     String?
  registrationNumber        String?
  countryCode               String                   @db.Char(2)
  currency                  String                   @db.Char(3)
  email                     String?
  phone                     String?
  website                   String?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  postalCode                String?
  status                    ContractorStatus         @default(ACTIVE)
  lifecycleStage            ContractorLifecycleStage @default(DRAFT)
  ownerUserId               String?
  primaryTeamId             String?
  primaryProjectId          String?
  defaultCostCenterId       String?
  // Phase 74 D-02 — KT role tag for offboarding template auto-selection (NULL → Generic Consultant fallback)
  workflowRoleId            String?
  notes                     String?
  isSensitive               Boolean                  @default(false)
  customFieldsJson          Json?
  countryFields             Json? // Country-specific compliance fields (validated by Zod per country)
  // Phase 57 (D-05) — denormalized VAT validation summary (source of truth = TaxIdValidation)
  latestVatValidatedAt      DateTime?
  latestVatValidationStatus ValidationStatus?
  // Phase 61 (D-08 / D-11) — German public-sector Leitweg-ID flag + Peppol ID pair
  isPublicSectorBuyer       Boolean                  @default(false)
  peppolSchemeId            String?                  @db.VarChar(4)
  peppolParticipantValue    String?                  @db.VarChar(64)
  // Phase 63 (D-11) — B2B customer flag for LPCDA late payment interest eligibility
  isBusinessCustomer        Boolean                  @default(true)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  archivedAt                DateTime?
  deletedAt                 DateTime?
  search_vector             Unsupported("tsvector")?

  organization      Organization          @relation(fields: [organizationId], references: [id])
  owner             User?                 @relation("ContractorOwner", fields: [ownerUserId], references: [id])
  primaryTeam       Team?                 @relation(fields: [primaryTeamId], references: [id])
  primaryProject    Project?              @relation(fields: [primaryProjectId], references: [id])
  defaultCostCenter CostCenter?           @relation(fields: [defaultCostCenterId], references: [id])
  workflowRole      WorkflowRoleTemplate? @relation(fields: [workflowRoleId], references: [id])

  contacts                  ContractorContact[]
  billingProfiles           ContractorBillingProfile[]
  assignments               ContractorAssignment[]
  contracts                 Contract[]
  complianceItems           ContractorComplianceItem[]
  workflowRuns              WorkflowRun[]
  invoices                  Invoice[]
  paymentRunItems           PaymentRunItem[]
  tags                      ContractorTagLink[]
  portalSessions            PortalSession[]
  changeRequests            ContractorChangeRequest[]
  notificationPreferences   ContractorNotificationPreference[]
  timesheets                Timesheet[]
  timeEntries               TimeEntry[]
  equipmentAssignments      EquipmentAssignment[]
  returnRequests            ReturnRequest[]
  taxIdValidations          TaxIdValidation[]
  ir35ChainParticipantLinks Ir35ChainParticipant[]
  leitwegIds                LeitwegId[]
  intakes                   InvoiceIntakeRequest[]             @relation("InvoiceIntakeMatchedContractor")
  deprovisioningRuns        DeprovisioningRun[]

  // InPost preferred Paczkomat (D-03)
  preferredPaczkomatId      String?
  preferredPaczkomatName    String?
  preferredPaczkomatAddress String?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, lifecycleStage])
  @@index([organizationId, ownerUserId])
  @@index([organizationId, legalName])
  @@index([organizationId, taxId])
  @@index([organizationId, workflowRoleId])
}

model ContractorContact {
  id             String   @id @default(cuid())
  organizationId String
  contractorId   String
  fullName       String
  email          String
  phone          String?
  roleTitle      String?
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  contractor   Contractor   @relation(fields: [contractorId], references: [id])

  @@index([organizationId])
  @@index([organizationId, contractorId])
}

model ContractorBillingProfile {
  id                   String    @id @default(cuid())
  organizationId       String
  contractorId         String
  legalEntityName      String
  billingEmail         String?
  countryCode          String    @db.Char(2)
  addressLine1         String?
  addressLine2         String?
  city                 String?
  postalCode           String?
  bankAccountMasked    String?
  bankAccountEncrypted String?
  bankName             String?
  swiftBic             String?   @db.VarChar(11)
  preferredCurrency    String    @db.Char(3)
  paymentTermsDays     Int?
  taxId                String?
  vatId                String?
  isDefault            Boolean   @default(false)
  validFrom            DateTime  @db.Date
  validTo              DateTime? @db.Date
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  contractor   Contractor   @relation(fields: [contractorId], references: [id])

  // Phase 63 (D-01) — UK BACS bank account fields (encrypted + masked pairs)
  ukSortCodeEncrypted      String?
  ukSortCodeMasked         String?
  ukAccountNumberEncrypted String?
  ukAccountNumberMasked    String?

  invoices        Invoice[]
  paymentRunItems PaymentRunItem[]
  skontoTerms     SkontoTerm[]

  @@index([organizationId])
  @@index([organizationId, contractorId])
  @@index([organizationId, isDefault])
}

model ContractorAssignment {
  id                String           @id @default(cuid())
  organizationId    String
  contractorId      String
  teamId            String?
  projectId         String?
  costCenterId      String?
  ownerUserId       String?
  allocationPercent Decimal?         @db.Decimal(5, 2)
  activeFrom        DateTime         @db.Date
  activeTo          DateTime?        @db.Date
  // Phase 76 D-06 — administrative termination instant; drives the 14-day deprovisioning
  // cooldown. Distinct from `activeTo` (calendar end-of-engagement date); written by
  // Phase 74's workflow ACCESS_REVOKE task hook when transitioning to status = ENDED.
  endedAt           DateTime?
  status            AssignmentStatus @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  contractor   Contractor   @relation(fields: [contractorId], references: [id])
  team         Team?        @relation(fields: [teamId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id])

  classificationAssessments    ClassificationAssessment[]
  ir35ChainParticipants        Ir35ChainParticipant[]
  ir35OtherClientAttestation   Ir35OtherClientAttestation?
  economicDependencyAlertState EconomicDependencyAlertState?
  reassessmentTriggers         ReassessmentTrigger[]
  statusfeststellungsverfahren Statusfeststellungsverfahren[]
  deprovisioningRuns           DeprovisioningRun[]

  @@index([organizationId])
  @@index([organizationId, contractorId, status])
}

model ContractorTag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String?  @db.VarChar(7)
  createdAt      DateTime @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id])
  contractors  ContractorTagLink[]

  @@unique([organizationId, name])
}

model ContractorTagLink {
  contractorId String
  tagId        String

  contractor Contractor    @relation(fields: [contractorId], references: [id])
  tag        ContractorTag @relation(fields: [tagId], references: [id])

  @@id([contractorId, tagId])
  @@index([tagId])
}

model ComplianceRequirementTemplate {
  id                      String          @id @default(cuid())
  organizationId          String
  name                    String
  appliesToContractorType ContractorType?
  documentType            DocumentType
  isRequired              Boolean
  expires                 Boolean
  defaultValidityDays     Int?
  createdAt               DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ContractorComplianceItem {
  id                    String           @id @default(cuid())
  organizationId        String
  contractorId          String
  contractId            String?
  requirementTemplateId String?
  name                  String
  documentType          DocumentType
  status                ComplianceStatus @default(MISSING)
  severity              Severity? // Phase 71 D-05 — null pre-backfill
  policyRuleId          String? // Phase 71 D-06 — value-checked at write against compliance-policy registry
  expiryJurisdictionTz  String? // Phase 71 D-07 — IANA TZ; set at row-creation, never rewritten
  waivedReason          WaivedReason? // Phase 71 D-11 — populated only when status = WAIVED
  dueDate               DateTime?        @db.Date
  satisfiedByDocumentId String?
  expiresAt             DateTime?        @db.Date
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  contractor   Contractor   @relation(fields: [contractorId], references: [id])
  contract     Contract?    @relation(fields: [contractId], references: [id])

  @@index([organizationId])
  @@index([organizationId, contractorId, status])
  @@index([organizationId, expiresAt])
  @@index([organizationId, policyRuleId]) // Phase 71 — supports drift queries by policyRuleId namespace
}

// --- Enums ---

enum ContractorType {
  SOLE_TRADER
  COMPANY
  INDIVIDUAL_FREELANCER
  OTHER
}

enum ContractorStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContractorLifecycleStage {
  DRAFT
  ONBOARDING
  ACTIVE
  OFFBOARDING
  ENDED
}

enum AssignmentStatus {
  ACTIVE
  ENDED
  PLANNED
}

enum ComplianceStatus {
  MISSING
  PENDING
  SATISFIED
  EXPIRED
  WAIVED
}

// Phase 71 D-05 — Severity 3-tier classification:
//   BLOCKING — Phase 72 hard-payment-block trigger (UK Right-to-Work missing, A1 expired)
//   WARNING  — Phase 73 admin-dashboard surface; does NOT block payment
//   INFO     — record-only; visible in audit reports
enum Severity {
  BLOCKING
  WARNING
  INFO
}

// Phase 71 D-11 — Closed enum for `waivedReason` audit-fidelity field.
// Strong type at the DB level, greppable in audit queries; prevents free-text drift.
enum WaivedReason {
  SUPERSEDED_BY_POLICY_VERSION // Policy version bump (D-09)
  CLASSIFICATION_OUTCOME_CHANGE // Outcome differs from prior assessment (D-10)
  ADMIN_MANUAL_WAIVE // Admin clicked "Waive this requirement" (existing UX)
  CONTRACTOR_OFFBOARDED // Phase 74/75 fires this on offboarding completion
}
