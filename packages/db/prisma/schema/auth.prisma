// Better Auth tables — User, Session, Account, Verification
// These are global models (not tenant-scoped)

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth admin plugin fields
  role       String?   @default("user")
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  // Account lockout (brute-force protection)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  sessions Session[]
  accounts Account[]

  // Organization relations
  members     Member[]
  invitations Invitation[]

  // Contractor relations
  ownedContractors Contractor[] @relation("ContractorOwner")
  managedTeams     Team[]       @relation("TeamManager")

  // Contract relations
  ownedContracts Contract[] @relation("ContractOwner")

  // Workflow relations
  startedWorkflowRuns    WorkflowRun[]     @relation("WorkflowRunStarter")
  assignedWorkflowTasks  WorkflowTaskRun[] @relation("WorkflowTaskAssignee")
  completedWorkflowTasks WorkflowTaskRun[] @relation("WorkflowTaskCompleter")

  // Approval relations
  createdApprovalFlows ApprovalFlow[]     @relation("ApprovalFlowCreator")
  approvalSteps        ApprovalStep[]     @relation("ApprovalStepApprover")
  approvalDecisions    ApprovalDecision[]

  // Payment relations
  createdPaymentRuns  PaymentRun[] @relation("PaymentRunCreator")
  approvedPaymentRuns PaymentRun[] @relation("PaymentRunApprover")

  // Integration relations
  integrationConnections IntegrationConnection[]
  personalConnections    IntegrationConnection[] @relation("personalConnections")

  // Communication relations
  notifications     Notification[]
  notificationPrefs UserNotificationPreference[]
  comments          Comment[]

  // Document relations
  paymentExports PaymentExport[]

  // Workflow comments
  workflowComments WorkflowComment[]

  // Portal change request reviews
  reviewedChangeRequests ContractorChangeRequest[]

  // E-sign relations
  sentSigningEnvelopes SigningEnvelope[] @relation("SigningEnvelopeSender")

  // Consent relations (Phase 51 — PDPL compliance)
  consentRecords ConsentRecord[] @relation("UserConsentRecords")

  // Time tracking relations
  reviewedTimesheets Timesheet[] @relation("TimesheetReviewer")

  // API key relations
  apiKeys OrganizationApiKey[]

  // Phase 59 — Classification documents (D-06)
  generatedClassificationDocuments ClassificationDocument[]

  // Phase 60 — CLASS-08 reassessment triggers
  acknowledgedReassessmentTriggers ReassessmentTrigger[] @relation("ReassessmentTriggerAck")
  dismissedReassessmentTriggers    ReassessmentTrigger[] @relation("ReassessmentTriggerDismiss")

  // Phase 62 — Invoice intake (D-09) — uploads + validation acknowledgements
  uploadedIntakes     InvoiceIntakeRequest[] @relation("InvoiceIntakeUploadedBy")
  acknowledgedIntakes InvoiceIntakeRequest[] @relation("InvoiceIntakeValidationAckBy")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
