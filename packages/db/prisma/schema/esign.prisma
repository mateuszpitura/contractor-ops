// SigningEnvelope, SigningRecipient, SigningEvent — e-sign integration models

model SigningEnvelope {
  id                      String                @id @default(cuid())
  organizationId          String
  integrationConnectionId String
  provider                IntegrationProvider
  externalEnvelopeId      String?
  contractId              String?
  documentId              String?
  status                  SigningEnvelopeStatus @default(CREATED)
  message                 String?
  expiresAt               DateTime?
  reminderIntervalDays    Int?
  sentByUserId            String
  sentAt                  DateTime?
  completedAt             DateTime?
  voidedAt                DateTime?
  voidReason              String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  sentBy       User               @relation("SigningEnvelopeSender", fields: [sentByUserId], references: [id])
  recipients   SigningRecipient[]
  events       SigningEvent[]

  @@unique([provider, externalEnvelopeId], map: "signing_envelope_provider_external_id_uniq")
  @@index([organizationId])
  @@index([organizationId, contractId])
  @@index([organizationId, status])
}

model SigningRecipient {
  id                  String                 @id @default(cuid())
  signingEnvelopeId   String
  externalRecipientId String?
  name                String
  email               String
  role                SigningRecipientRole
  routingOrder        Int
  status              SigningRecipientStatus @default(PENDING)
  signedAt            DateTime?
  declinedAt          DateTime?
  declineReason       String?
  viewedAt            DateTime?

  signingEnvelope SigningEnvelope @relation(fields: [signingEnvelopeId], references: [id])

  @@index([signingEnvelopeId])
}

model SigningEvent {
  id                String           @id @default(cuid())
  organizationId    String
  signingEnvelopeId String
  eventType         SigningEventType
  actorName         String?
  actorEmail        String?
  description       String
  providerEventId   String?
  occurredAt        DateTime
  createdAt         DateTime         @default(now())

  organization    Organization    @relation(fields: [organizationId], references: [id])
  signingEnvelope SigningEnvelope @relation(fields: [signingEnvelopeId], references: [id])

  @@index([organizationId, signingEnvelopeId, occurredAt])
}

// Pre-provider idempotency ledger for envelope creation. The orchestrator creates
// the provider envelope BEFORE the local DB transaction; if that transaction rolls
// back, a retry would re-issue the provider call and duplicate the process. DocuSign
// is protected by its server-honored X-DocuSign-Idempotency-Key, but Autenti's
// POST /document-processes accepts no idempotency header or client reference, so the
// dedup must live on our side: the service writes an intent row keyed on the
// deterministic business key BEFORE the provider call and short-circuits when one
// already exists, recording externalEnvelopeId once the provider create returns.
model EsignEnvelopeIntent {
  id                      String              @id @default(cuid())
  organizationId          String
  documentId              String
  contractId              String?
  provider                IntegrationProvider
  integrationConnectionId String
  // Service-computed digest of the logical signer set (e.g. sorted signer emails +
  // roles/routing) that, together with org + document, identifies one logical send.
  signerSetHash           String
  // Provider process/envelope id, written once the provider create succeeds; null
  // while the create is in-flight or after a failed attempt (so a retry re-drives).
  externalEnvelopeId      String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, documentId, signerSetHash], map: "esign_envelope_intent_dedup_key")
  @@index([organizationId])
  @@index([organizationId, documentId])
}

// --- Enums ---

enum SigningEnvelopeStatus {
  CREATED
  SENT
  DELIVERED
  COMPLETED
  DECLINED
  VOIDED
  EXPIRED
}

enum SigningRecipientRole {
  SIGNER
  COUNTERSIGNER
}

enum SigningRecipientStatus {
  PENDING
  SENT
  DELIVERED
  VIEWED
  SIGNED
  DECLINED
}

enum SigningEventType {
  ENVELOPE_CREATED
  ENVELOPE_SENT
  RECIPIENT_VIEWED
  RECIPIENT_SIGNED
  RECIPIENT_DECLINED
  ENVELOPE_COMPLETED
  ENVELOPE_VOIDED
  ENVELOPE_EXPIRED
  SIGNED_PDF_SAVED
}
