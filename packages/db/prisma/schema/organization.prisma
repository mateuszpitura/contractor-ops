// Organization, Member, Invitation (Better Auth organization plugin)
// Plus Team, Project, CostCenter

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  // Custom fields from db-schema.md
  legalName            String?
  countryCode          String?            @db.Char(2)
  dataRegion           DataRegion         @default(EU)
  defaultCurrency      String?            @db.Char(3)
  timezone             String?
  language             String?
  fiscalYearStartMonth Int?               @default(1)
  status               OrganizationStatus @default(ACTIVE)
  // Phase 57 (D-11) — Kleinunternehmerregelung §19 UStG toggle (DE orgs only)
  isKleinunternehmer   Boolean            @default(false)
  billingEmail         String?
  settingsJson         Json?
  portalSubdomain      String?            @unique
  portalCustomDomain   String?            @unique
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  // Relations
  members                        Member[]
  invitations                    Invitation[]
  teams                          Team[]
  projects                       Project[]
  costCenters                    CostCenter[]
  contractors                    Contractor[]
  contractorContacts             ContractorContact[]
  contractorBillingProfiles      ContractorBillingProfile[]
  contractorAssignments          ContractorAssignment[]
  contractorTags                 ContractorTag[]
  contracts                      Contract[]
  contractAmendments             ContractAmendment[]
  contractRatePeriods            ContractRatePeriod[]
  documents                      Document[]
  documentLinks                  DocumentLink[]
  complianceTemplates            ComplianceRequirementTemplate[]
  complianceItems                ContractorComplianceItem[]
  workflowTemplates              WorkflowTemplate[]
  workflowTaskTemplates          WorkflowTaskTemplate[]
  workflowRuns                   WorkflowRun[]
  workflowTaskRuns               WorkflowTaskRun[]
  workflowComments               WorkflowComment[]
  workflowAttachments            WorkflowAttachment[]
  invoices                       Invoice[]
  invoiceFiles                   InvoiceFile[]
  invoiceLines                   InvoiceLine[]
  invoiceMatchResults            InvoiceMatchResult[]
  approvalChainConfigs           ApprovalChainConfig[]
  approvalFlows                  ApprovalFlow[]
  approvalSteps                  ApprovalStep[]
  approvalDecisions              ApprovalDecision[]
  paymentRuns                    PaymentRun[]
  paymentRunItems                PaymentRunItem[]
  paymentExports                 PaymentExport[]
  auditLogs                      AuditLog[]
  outboxEvents                   OutboxEvent[]
  integrationConnections         IntegrationConnection[]
  externalLinks                  ExternalLink[]
  integrationSyncLogs            IntegrationSyncLog[]
  webhookDeliveries              WebhookDelivery[]
  portalSessions                 PortalSession[]
  contractorChangeRequests       ContractorChangeRequest[]
  contractorNotificationPrefs    ContractorNotificationPreference[]
  notifications                  Notification[]
  notificationPrefs              UserNotificationPreference[]
  comments                       Comment[]
  reminderRules                  ReminderRule[]
  reminderInstances              ReminderInstance[]
  signingEnvelopes               SigningEnvelope[]
  signingEvents                  SigningEvent[]
  ocrExtractions                 OcrExtraction[]
  timesheets                     Timesheet[]
  timeEntries                    TimeEntry[]
  subscription                   Subscription?
  ocrCreditLedger                OcrCreditLedger[]
  equipment                      Equipment[]
  equipmentAssignments           EquipmentAssignment[]
  shipments                      Shipment[]
  shipmentEvents                 ShipmentEvent[]
  returnRequests                 ReturnRequest[]
  courierConfigs                 CourierConfig[]
  consentRecords                 ConsentRecord[]
  privacyNotices                 PrivacyNotice[]
  peppolParticipants             PeppolParticipant[]
  peppolTransmissions            PeppolTransmission[]
  govApiAuditLogs                GovApiAuditLog[]
  zatcaChainEntries              ZatcaInvoiceChain[]
  taxIdValidations               TaxIdValidation[]
  apiKeys                        OrganizationApiKey[]
  classificationAssessments      ClassificationAssessment[]
  classificationDocuments        ClassificationDocument[]
  ir35ChainParticipants          Ir35ChainParticipant[]
  ir35ChainParticipantLinkedOrgs Ir35ChainParticipant[]             @relation("Ir35ChainParticipantLinkedOrg")
  ir35OtherClientAttestations    Ir35OtherClientAttestation[]
  economicDependencyAlertStates  EconomicDependencyAlertState[]
  reassessmentTriggers           ReassessmentTrigger[]
  statusfeststellungsverfahren   Statusfeststellungsverfahren[]
  leitwegIds                     LeitwegId[]
  eInvoiceLifecycles             EInvoiceLifecycle[]
  eInvoiceLifecycleEvents        EInvoiceLifecycleEvent[]
  peppolCapabilityCache          PeppolCapabilityCache[]
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String
  teamId         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id])

  @@index([organizationId])
  @@index([organizationId, userId])
  @@index([organizationId, role])
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String
  status         String
  expiresAt      DateTime
  inviterId      String

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id])

  @@index([organizationId])
}

// --- Organizational Structure ---

model Team {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  code           String?
  managerUserId  String?
  status         SimpleStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  manager      User?        @relation("TeamManager", fields: [managerUserId], references: [id])

  members               Member[]
  contractors           Contractor[]
  projects              Project[]
  contractorAssignments ContractorAssignment[]
  contracts             Contract[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  code           String?
  teamId         String?
  status         SimpleStatus @default(ACTIVE)
  startDate      DateTime?    @db.Date
  endDate        DateTime?    @db.Date
  budgetMinor    Int?
  budgetCurrency String?      @db.Char(3)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  team         Team?        @relation(fields: [teamId], references: [id])

  contractors           Contractor[]
  contractorAssignments ContractorAssignment[]
  contracts             Contract[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, teamId])
}

model CostCenter {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  code           String
  status         SimpleStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  contractors           Contractor[]
  contractorAssignments ContractorAssignment[]
  contracts             Contract[]

  @@unique([organizationId, code])
}

// --- Enums ---

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  ARCHIVED
}

enum SimpleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DataRegion {
  EU
  ME
}
