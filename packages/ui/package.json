{
  "name": "@contractor-ops/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/shadcn": {
      "types": "./dist/components/shadcn/index.d.ts",
      "import": "./dist/components/shadcn/index.js"
    },
    "./components/shadcn/*": {
      "types": "./dist/components/shadcn/*.d.ts",
      "import": "./dist/components/shadcn/*.js"
    },
    "./components/magic": {
      "types": "./dist/components/magic/index.d.ts",
      "import": "./dist/components/magic/index.js"
    },
    "./components/magic/*": {
      "types": "./dist/components/magic/*.d.ts",
      "import": "./dist/components/magic/*.js"
    },
    "./components/ace": {
      "types": "./dist/components/ace/index.d.ts",
      "import": "./dist/components/ace/index.js"
    },
    "./components/ace/*": {
      "types": "./dist/components/ace/*.d.ts",
      "import": "./dist/components/ace/*.js"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.js"
    },
    "./hooks/use-mobile": {
      "types": "./dist/hooks/use-mobile.d.ts",
      "import": "./dist/hooks/use-mobile.js"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/glass.css": "./src/styles/glass.css",
    "./styles/motion.css": "./src/styles/motion.css",
    "./styles/status.css": "./src/styles/status.css",
    "./styles/registry-css.css": "./src/styles/registry-css.css"
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react-day-picker": "^9.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "motion": "^12.38.0",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "motion": "^12.38.0",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3"
  }
}
