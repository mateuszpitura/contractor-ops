{
  "name": "@contractor-ops/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/shadcn": {
      "types": "./dist/components/shadcn/index.d.ts",
      "import": "./dist/components/shadcn/index.js"
    },
    "./components/shadcn/*": {
      "types": "./dist/components/shadcn/*.d.ts",
      "import": "./dist/components/shadcn/*.js"
    },
    "./components/magic": {
      "types": "./dist/components/magic/index.d.ts",
      "import": "./dist/components/magic/index.js"
    },
    "./components/magic/*": {
      "types": "./dist/components/magic/*.d.ts",
      "import": "./dist/components/magic/*.js"
    },
    "./components/ace": {
      "types": "./dist/components/ace/index.d.ts",
      "import": "./dist/components/ace/index.js"
    },
    "./components/ace/*": {
      "types": "./dist/components/ace/*.d.ts",
      "import": "./dist/components/ace/*.js"
    },
    "./components/cult": {
      "types": "./dist/components/cult/index.d.ts",
      "import": "./dist/components/cult/index.js"
    },
    "./components/cult/*": {
      "types": "./dist/components/cult/*.d.ts",
      "import": "./dist/components/cult/*.js"
    },
    "./components/origin": {
      "types": "./dist/components/origin/index.d.ts",
      "import": "./dist/components/origin/index.js"
    },
    "./components/origin/*": {
      "types": "./dist/components/origin/*.d.ts",
      "import": "./dist/components/origin/*.js"
    },
    "./components/reui": {
      "types": "./dist/components/reui/index.d.ts",
      "import": "./dist/components/reui/index.js"
    },
    "./components/reui/*": {
      "types": "./dist/components/reui/*.d.ts",
      "import": "./dist/components/reui/*.js"
    },
    "./components/tailark": {
      "types": "./dist/components/tailark/index.d.ts",
      "import": "./dist/components/tailark/index.js"
    },
    "./components/tailark/*": {
      "types": "./dist/components/tailark/*.d.ts",
      "import": "./dist/components/tailark/*.js"
    },
    "./components/shadcnio": {
      "types": "./dist/components/shadcnio/index.d.ts",
      "import": "./dist/components/shadcnio/index.js"
    },
    "./components/shadcnio/*": {
      "types": "./dist/components/shadcnio/*.d.ts",
      "import": "./dist/components/shadcnio/*.js"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.js"
    },
    "./lib/form-control": {
      "types": "./dist/lib/form-control.d.ts",
      "import": "./dist/lib/form-control.js"
    },
    "./lib/row-click": {
      "types": "./dist/lib/row-click.d.ts",
      "import": "./dist/lib/row-click.js"
    },
    "./marketing": {
      "types": "./dist/marketing/index.d.ts",
      "import": "./dist/marketing/index.js",
      "default": "./dist/marketing/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/translations-provider.d.ts",
      "import": "./dist/i18n/translations-provider.js"
    },
    "./hooks/use-mobile": {
      "types": "./dist/hooks/use-mobile.d.ts",
      "import": "./dist/hooks/use-mobile.js"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/form-control.css": "./src/styles/form-control.css",
    "./styles/glass.css": "./src/styles/glass.css",
    "./styles/motion.css": "./src/styles/motion.css",
    "./styles/status.css": "./src/styles/status.css",
    "./styles/registry-css.css": "./src/styles/registry-css.css"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotted-map": "^3.1.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
