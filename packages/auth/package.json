{
  "name": "@contractor-ops/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./role-normalization": {
      "types": "./src/role-normalization.ts",
      "import": "./dist/role-normalization.js",
      "default": "./dist/role-normalization.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contractor-ops/db": "workspace:*",
    "better-auth": "^1.6.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
