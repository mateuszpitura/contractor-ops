{
  "name": "contractor-ops",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:no-process-env": "node scripts/check-no-process-env.mjs",
    "lint:schema": "tsx scripts/lint-schema.mjs",
    "lint:logs": "tsx scripts/lint-logs.mjs",
    "i18n:parity": "tsx scripts/i18n-parity.mjs",
    "test": "turbo test",
    "test:coverage": "turbo build --filter=@contractor-ops/validators --filter=@contractor-ops/auth --filter=@contractor-ops/integrations --filter=@contractor-ops/logger && vitest run --coverage",
    "load:smoke": "k6 run load-tests/smoke.js",
    "load:api": "k6 run load-tests/api-read.js",
    "load:stress": "k6 run -e K6_PROFILE=stress load-tests/api-read.js",
    "load:writes": "k6 run load-tests/api-write.js",
    "load:writes:stress": "k6 run -e K6_PROFILE=stress load-tests/api-write.js",
    "e2e:perf": "pnpm --filter @contractor-ops/web run e2e:perf",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "postinstall": "turbo build --filter=@contractor-ops/validators --filter=@contractor-ops/auth --filter=@contractor-ops/integrations --filter=@contractor-ops/logger --filter=@contractor-ops/api",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tinyglobby": "^0.2.15",
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "biome check --write --no-errors-on-unmatched",
    "*.prisma": "bash -c 'cd packages/db && npx prisma format'"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "defu": ">=6.1.5",
      "path-to-regexp": ">=8.4.0"
    }
  }
}
