{
  "name": "contractor-ops",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:ci": "biome check --config-path=biome.ci.json . && pnpm lint:i18n-casts",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "typecheck:fast": "turbo typecheck:fast",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:no-process-env": "node scripts/check-no-process-env.mjs",
    "lint:schema": "tsx scripts/lint-schema.mjs",
    "lint:logs": "tsx scripts/lint-logs.mjs",
    "lint:raw-sql": "tsx scripts/check-raw-sql-tenant-scoped.ts",
    "lint:audit-log": "node scripts/lint-audit-log.mjs",
    "lint:raw-fetch": "node scripts/lint-raw-fetch.mjs",
    "lint:idempotency": "node scripts/lint-idempotency.mjs",
    "lint:silent-catch": "node scripts/lint-silent-catch.mjs",
    "i18n:parity": "tsx scripts/i18n-parity.mjs",
    "i18n:code-coverage": "tsx scripts/audit-i18n-code-coverage.ts --allow-hardcoded",
    "i18n:quality": "tsx scripts/audit-translations-quality.ts",
    "i18n:types": "tsx scripts/generate-i18n-types.ts",
    "lint:i18n-casts": "tsx scripts/lint-i18n-casts.ts",
    "setup:dev-services": "node scripts/seed-dev-services.mjs",
    "security:scan": "bash scripts/security-scan.sh",
    "test": "turbo test",
    "test:coverage": "turbo build --filter=@contractor-ops/validators --filter=@contractor-ops/auth --filter=@contractor-ops/integrations --filter=@contractor-ops/logger && vitest run --coverage",
    "load:smoke": "k6 run load-tests/smoke.js",
    "load:api": "k6 run load-tests/api-read.js",
    "load:stress": "k6 run -e K6_PROFILE=stress load-tests/api-read.js",
    "load:writes": "k6 run load-tests/api-write.js",
    "load:writes:stress": "k6 run -e K6_PROFILE=stress load-tests/api-write.js",
    "e2e:perf": "pnpm --filter @contractor-ops/web run e2e:perf",
    "db:generate": "turbo db:generate",
    "db:migrate:dev": "pnpm -F @contractor-ops/db run db:migrate:dev",
    "db:migrate:all": "pnpm -F @contractor-ops/db run db:migrate:all",
    "db:seed:dev": "pnpm -F @contractor-ops/db run db:seed:dev",
    "seed:qa": "pnpm -F @contractor-ops/db exec tsx scripts/seed-dev.ts --profile=qa --confirm --regions=EU --seed=4242 && pnpm -F @contractor-ops/cms run seed:qa",
    "qa:walk": "pnpm -F @contractor-ops/qa-walk run walk --",
    "postinstall": "turbo build --filter=@contractor-ops/validators --filter=@contractor-ops/auth --filter=@contractor-ops/integrations --filter=@contractor-ops/logger --filter=@contractor-ops/api",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260506.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "tinyglobby": "^0.2.16",
    "tsx": "^4.21.0",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.1044.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "biome check --write --no-errors-on-unmatched",
    "*.prisma": "bash -c 'cd packages/db && npx prisma format'"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "$@types/node",
      "defu": "6.1.7",
      "path-to-regexp": "8.4.2",
      "@payloadcms/next>path-to-regexp": "6.3.0",
      "axios": "1.16.0",
      "protobufjs": "7.5.6",
      "@xmldom/xmldom": "0.8.13",
      "kysely": "0.28.17",
      "fast-uri": "3.1.2",
      "dompurify": "3.4.2",
      "@protobufjs/utf8": "1.1.1",
      "brace-expansion": "5.0.5",
      "follow-redirects": "1.16.0",
      "ip-address": "10.2.0",
      "postcss": "8.5.14",
      "vite": "8.0.10",
      "fast-xml-builder": "1.1.9"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "@swc/core",
      "esbuild",
      "libxmljs2",
      "msw",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  }
}
