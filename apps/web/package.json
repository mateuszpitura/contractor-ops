    "@contractor-ops/einvoice": "workspace:*",
    "@contractor-ops/db": "workspace:^",
    "@contractor-ops/integrations": "workspace:*",
    "@contractor-ops/logger": "workspace:*",
    "@contractor-ops/validators": "workspace:*",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^9.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@trpc/tanstack-react-query": "^11.0.0",
