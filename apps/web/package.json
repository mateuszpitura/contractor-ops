{
  "name": "@contractor-ops/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev",
    "build": "dotenv -e ../../.env -- next build",
    "start": "dotenv -e ../../.env -- next start",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.all --coverage.include='src/components/**/*.tsx'",
    "e2e:perf": "playwright test -c playwright.perf.config.ts",
    "e2e:perf:install": "playwright install chromium",
    "e2e:integration": "playwright test -c playwright.integration.config.ts",
    "e2e:integration:install": "playwright install chromium"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
