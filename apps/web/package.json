    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "^15.3.0",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "postcss": "^8.5.8",
