{
  "name": "@contractor-ops/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096\" dotenv -e ../../.env -- next dev --turbopack",
    "build": "dotenv -e ../../.env -- next build --webpack",
    "start": "dotenv -e ../../.env -- next start",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.all --coverage.include='src/components/**/*.tsx'",
    "e2e:perf": "playwright test -c playwright.perf.config.ts",
    "e2e:perf:install": "playwright install chromium",
    "e2e:integration": "playwright test -c playwright.integration.config.ts",
    "e2e:integration:install": "playwright install chromium",
    "e2e:rtl": "playwright test -c playwright.rtl.config.ts",
    "e2e:rtl:install": "playwright install chromium",
    "e2e:functional": "playwright test -c playwright.functional.config.ts",
    "e2e:functional:install": "playwright install chromium",
    "test:a11y": "playwright test --config=playwright.functional.config.ts --project=a11y",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit",
    "i18n:types": "tsx ../../scripts/generate-i18n-types.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@contractor-ops/api": "workspace:*",
    "@contractor-ops/auth": "workspace:*",
    "@contractor-ops/classification": "workspace:*",
    "@contractor-ops/db": "workspace:^",
    "@contractor-ops/einvoice": "workspace:*",
    "@contractor-ops/feature-flags": "workspace:*",
    "@contractor-ops/integrations": "workspace:*",
    "@contractor-ops/logger": "workspace:*",
    "@contractor-ops/ui": "workspace:*",
    "@contractor-ops/validators": "workspace:*",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.1",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.51.0",
    "@sentry/node": "^10.51.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "@upstash/qstash": "^2.10.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.6.9",
    "botbuilder": "^4.23.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.5",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "nuqs": "^2.8.9",
    "pino": "^10.3.1",
    "postcss": "^8.5.12",
    "proxy-addr": "^2.0.7",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.6.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/proxy-addr": "^2.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.1.1",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
