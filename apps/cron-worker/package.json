{
  "name": "@contractor-ops/cron-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:watch": "dotenv -e ../../.env -- vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit"
  },
  "dependencies": {
    "@contractor-ops/api": "workspace:*",
    "@contractor-ops/compliance-policy": "workspace:*",
    "@contractor-ops/db": "workspace:*",
    "@contractor-ops/feature-flags": "workspace:*",
    "@contractor-ops/idp-saga": "workspace:*",
    "@contractor-ops/integrations": "workspace:*",
    "@contractor-ops/logger": "workspace:*",
    "@contractor-ops/validators": "workspace:*",
    "@sentry/node": "^10.51.0",
    "fastify": "^5.6.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
