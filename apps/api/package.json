{
  "name": "@contractor-ops/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:watch": "dotenv -e ../../.env -- vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@contractor-ops/api": "workspace:*",
    "@contractor-ops/auth": "workspace:*",
    "@contractor-ops/db": "workspace:*",
    "@contractor-ops/einvoice": "workspace:*",
    "@contractor-ops/feature-flags": "workspace:*",
    "@contractor-ops/integrations": "workspace:*",
    "@contractor-ops/logger": "workspace:*",
    "@contractor-ops/validators": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@microsoft/agents-activity": "^1.5.2",
    "@microsoft/agents-hosting": "^1.5.2",
    "@microsoft/agents-hosting-extensions-teams": "^1.5.2",
    "@sentry/node": "^10.51.0",
    "@trpc/server": "^11.17.0",
    "@upstash/qstash": "^2.10.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "fastify": "^5.6.1",
    "proxy-addr": "^2.0.7",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/proxy-addr": "^2.0.3",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
