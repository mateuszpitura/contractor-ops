{
  "name": "@contractor-ops/public-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit"
  },
  "dependencies": {
    "@contractor-ops/api": "workspace:*",
    "@contractor-ops/db": "workspace:*",
    "@contractor-ops/logger": "workspace:*",
    "@contractor-ops/validators": "workspace:*",
    "@sentry/node": "^10.51.0",
    "@trpc/server": "^11.17.0",
    "@hono/node-server": "^2.0.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@contractor-ops/test-utils": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
