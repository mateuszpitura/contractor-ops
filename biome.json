{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended",
      "next": "recommended",
      "test": "recommended",
      "project": "recommended",
      "types": "recommended"
    },
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["warn", "error", "info"] }
        },
        "noEmptyBlockStatements": "error",
        "noEvolvingTypes": "error"
      },
      "style": {
        "useImportType": {
          "level": "error",
          "options": {
            "style": "separatedType"
          }
        },
        "useThrowNewError": "error",
        "useConsistentArrayType": {
          "level": "warn",
          "options": { "syntax": "shorthand" }
        }
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noBarrelFile": "warn",
        "noReExportAll": "warn"
      },
      "complexity": {
        "noUselessUndefined": "error",
        "noExcessiveCognitiveComplexity": "warn",
        "noForEach": "error",
        "useDateNow": "error",
        "useSimplifiedLogicExpression": "warn"
      },
      "nursery": {
        "noNestedPromises": "error",
        "noLeakedRender": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/generated",
      "!**/prisma/migrations",
      "!**/dist",
      "!**/.turbo",
      "!**/.claude",
      "!**/out",
      "!**/coverage",
      "!**/playwright-report"
    ]
  }
}
