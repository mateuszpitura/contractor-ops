{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true,
      "bracketSameLine": true,
      "quoteProperties": "asNeeded"
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended",
      "next": "recommended",
      "test": "recommended",
      "project": "recommended",
      "types": "recommended"
    },
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["warn", "error", "info"] }
        },
        "noArrayIndexKey": "warn",
        "noEmptyBlockStatements": "error",
        "noEvolvingTypes": "error"
      },
      "style": {
        "useImportType": {
          "level": "error",
          "options": {
            "style": "separatedType"
          }
        },
        "useThrowNewError": "error",
        "useConsistentArrayType": {
          "level": "warn",
          "options": { "syntax": "shorthand" }
        },
        "noParameterAssign": "error",
        "useExponentiationOperator": "error",
        "noNegationElse": "warn",
        "useNodejsImportProtocol": "error",
        "noNonNullAssertion": "warn"
      },
      "correctness": {
        "useImportExtensions": "off",
        "noUnresolvedImports": "off",
        "useUniqueElementIds": "warn",
        "noUndeclaredDependencies": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noBarrelFile": "warn",
        "noReExportAll": "warn"
      },
      "complexity": {
        "noUselessUndefined": "error",
        "noExcessiveCognitiveComplexity": "warn",
        "noForEach": "error",
        "useDateNow": "error",
        "useSimplifiedLogicExpression": "warn"
      },
      "a11y": {
        "noLabelWithoutControl": "warn",
        "useButtonType": "warn",
        "useSemanticElements": "warn",
        "noStaticElementInteractions": "warn",
        "useKeyWithClickEvents": "warn",
        "useAriaPropsSupportedByRole": "warn",
        "useValidAnchor": "warn",
        "noSvgWithoutTitle": "warn",
        "useAnchorContent": "warn",
        "useFocusableInteractive": "warn",
        "noRedundantRoles": "warn"
      },
      "nursery": {
        "noNestedPromises": "error",
        "noLeakedRender": "warn",
        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "noDuplicateEnumValues": "error",
        "noImpliedEval": "error",
        "noMultiAssign": "error",
        "noForIn": "error",
        "noMultiStr": "error",
        "noInlineStyles": "warn",
        "noJsxPropsBind": "warn",
        "noPlaywrightMissingAwait": "error",
        "noPlaywrightForceOption": "warn",
        "noPlaywrightElementHandle": "warn",
        "noPlaywrightEval": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/generated",
      "!**/prisma/migrations",
      "!**/dist",
      "!**/.turbo",
      "!**/.claude",
      "!**/out",
      "!**/coverage",
      "!**/playwright-report"
    ]
  }
}
