{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true,
      "bracketSameLine": true,
      "quoteProperties": "asNeeded"
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended",
      "next": "recommended",
      "test": "recommended"
    },
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsole": {
          "level": "error",
          "options": { "allow": [] }
        },
        "noArrayIndexKey": "warn",
        "noEmptyBlockStatements": "error",
        "noEvolvingTypes": "error"
      },
      "style": {
        "useImportType": {
          "level": "error",
          "options": {
            "style": "separatedType"
          }
        },
        "useThrowNewError": "error",
        "useConsistentArrayType": {
          "level": "warn",
          "options": { "syntax": "shorthand" }
        },
        "noParameterAssign": "error",
        "useExponentiationOperator": "error",
        "noNegationElse": "warn",
        "useNodejsImportProtocol": "error",
        "noNonNullAssertion": "warn",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false,
            "requireAscii": true,
            "conventions": [
              {
                "selector": { "kind": "objectLiteralProperty" },
                "match": ".*"
              },
              {
                "selector": { "kind": "typeProperty" },
                "match": ".*"
              },
              {
                "selector": { "kind": "enumMember" },
                "formats": ["CONSTANT_CASE", "PascalCase", "camelCase"]
              },
              {
                "selector": { "kind": "const" },
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              },
              {
                "selector": { "kind": "let" },
                "formats": ["camelCase", "PascalCase"]
              },
              {
                "selector": { "kind": "var" },
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              }
            ]
          }
        }
      },
      "correctness": {
        "useImportExtensions": "off",
        "noUnresolvedImports": "off",
        "useUniqueElementIds": "warn",
        "noUndeclaredDependencies": "off",
        "noUnusedVariables": "error"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noBarrelFile": "warn",
        "noReExportAll": "warn"
      },
      "complexity": {
        "noUselessUndefined": "error",
        "noExcessiveCognitiveComplexity": "warn",
        "noForEach": "error",
        "useDateNow": "error",
        "useSimplifiedLogicExpression": "warn"
      },
      "a11y": {
        "noLabelWithoutControl": "warn",
        "useButtonType": "warn",
        "useSemanticElements": "warn",
        "noStaticElementInteractions": "warn",
        "useKeyWithClickEvents": "warn",
        "useAriaPropsSupportedByRole": "warn",
        "useValidAnchor": "warn",
        "noSvgWithoutTitle": "warn",
        "useAnchorContent": "warn",
        "useFocusableInteractive": "warn",
        "noRedundantRoles": "warn"
      },
      "nursery": {
        "noNestedPromises": "error",
        "noLeakedRender": "warn",
        "noDuplicateEnumValues": "error",
        "noImpliedEval": "error",
        "noMultiAssign": "error",
        "noForIn": "error",
        "noMultiStr": "error",
        "noInlineStyles": "warn",
        "noJsxPropsBind": "warn",
        "noPlaywrightMissingAwait": "error",
        "noPlaywrightForceOption": "warn",
        "noPlaywrightElementHandle": "warn",
        "noPlaywrightEval": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["apps/web-vite/src/**"],
      "plugins": [
        "./tools/biome-plugins/no-untranslated-toast.grit",
        "./tools/biome-plugins/no-untranslated-zod-message.grit"
      ]
    },
    {
      "includes": ["packages/api/src/**"],
      "plugins": ["./tools/biome-plugins/no-untranslated-trpc-error.grit"]
    },
    {
      "includes": [
        "packages/*/src/index.ts",
        "packages/*/src/*/index.ts",
        "packages/*/src/*/*/index.ts",
        "packages/*/src/*/*/*/index.ts",
        "packages/test-utils/src/msw/*/index.ts",
        "apps/landing/src/i18n/index.ts",
        "packages/api/src/routers/workflow/workflow.ts",
        "packages/api/src/routers/**/index.ts",
        "packages/ui/src/components/workbench/data-table/row-click.ts",
        "packages/validators/src/zatca.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/e2e/**"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noImgElement": "off"
          },
          "suspicious": {
            "noConsole": "off",
            "noExplicitAny": "off",
            "noEmptyBlockStatements": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "nursery": {
            "noJsxPropsBind": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/ui/src/components/workbench/empty-state-illustrations.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noSvgWithoutTitle": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/einvoice/src/profiles/*/validator-bundle/*.sef.{js,json}"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/cms/migrations/**", "apps/cms/src/payload-types.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedFunctionParameters": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          },
          "complexity": {
            "noBannedTypes": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/**", "load-tests/**", "goals/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "useNamingConvention": "off",
            "useTemplate": "off",
            "noNonNullAssertion": "off",
            "noParameterAssign": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/ui/src/components/ace/**",
        "packages/ui/src/components/atelier/**",
        "packages/ui/src/components/cult/**",
        "packages/ui/src/components/magic/**",
        "packages/ui/src/components/origin/**",
        "packages/ui/src/components/reui/**",
        "packages/ui/src/components/shadcn/**",
        "packages/ui/src/components/shadcnio/**",
        "packages/ui/src/components/tailark/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noArrayIndexKey": "off"
          },
          "performance": {
            "noImgElement": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off",
            "useUniqueElementIds": "off"
          },
          "style": {
            "noNonNullAssertion": "off",
            "useConsistentArrayType": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "a11y": {
            "noSvgWithoutTitle": "off",
            "noStaticElementInteractions": "off",
            "useKeyWithClickEvents": "off",
            "useAriaPropsSupportedByRole": "off",
            "useSemanticElements": "off"
          },
          "nursery": {
            "noLeakedRender": "off",
            "noInlineStyles": "off"
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/generated",
      "!**/prisma/migrations",
      "!**/dist",
      "!**/.turbo",
      "!**/.claude",
      "!**/.cursor",
      "!**/.agents",
      "!**/.github",
      "!**/.planning",
      "!**/.audit-scratch",
      "!**/out",
      "!**/coverage",
      "!**/playwright-report",
      "!**/next-env.d.ts",
      "!apps/cms/migrations",
      "!apps/cms/src/payload-types.ts"
    ]
  }
}
