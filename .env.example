# ── Core ─────────────────────────────────────────────────────────────────────
# Do NOT set NODE_ENV here — Next.js / Vitest / Playwright each set it to the
# correct value automatically. Pinning it to "development" in .env breaks
# `next build` (the App Router falls back to Pages-Router /_error + /404
# generators and emits the spurious "<Html> should not be imported outside of
# pages/_document" prerender error).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used by server-side adapters (DocuSign, Linear, Jira) for OAuth redirects
APP_URL=http://localhost:3000

# Primary data region for legal PDFs / cross-border detection (EU | ME)
DATA_HOSTING_REGION=EU

# ── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── Multi-Region Database (Neon projects) ───────────────────────────────────
DATABASE_URL_EU=postgresql://user:pass@eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_ME=postgresql://user:pass@eu-central-1.aws.neon.tech/neondb-me?sslmode=require

# ── F-SCALE-06 — Read replicas (optional, opt-in per call site) ─────────────
# When set, call sites that call `readReplica(region, …)` (currently only
# `dashboard.kpis`) route their reads to the replica instead of the writer.
# Failures fall back to the writer with a Pino warn breadcrumb; 5+ failures
# in 60s open a circuit breaker for 30s. Mutations and `$transaction` always
# go to the writer regardless. Leave unset locally.
DATABASE_URL_EU_RO=
DATABASE_URL_ME_RO=

# NEW-ARCH-01 — RLS bypass tripwire for `readReplica()`.
# Set to `true` once `CREATE POLICY` migrations are deployed; activates the
# tripwire in `readReplica()` (packages/db/src/replica.ts) so any call site
# that bypasses RLS scoping (raw PrismaClient, no `SET LOCAL app.org_id`)
# fails loudly instead of silently reading with NULL or being denied. Leave
# unset until policies actually exist in the schema. See
# .audit-2026-05-03/REVIEW-R3-ARCHITECTURE.md (NEW-ARCH-01).
RLS_POLICIES_ENFORCED=

# Advisory-lock single-arg → two-arg transition shim.
# Set to `true` for the deploy that ships commit ce8b26f4 (and the next ONE
# deploy cycle after) so post-refactor callers also acquire the legacy
# single-arg lock — pre-refactor in-flight holders then serialize correctly.
# Unset (or set to anything else) once every instance has rolled to the new
# code; the shim adds one extra Postgres round-trip per lock acquisition.
# Remove the env var AND the shim code in packages/api/src/lib/advisory-lock.ts
# (search for TODO(advisory-lock-transition)) once the transition is over.
ADVISORY_LOCK_TRANSITION_DUAL_HOLD=

# Slow-query warn threshold (ms). Default 200 is fine for native-protocol
# Postgres; raise it for Neon serverless HTTP (~100-150ms per-query overhead +
# scale-to-zero cold starts of 5-10s on the first query after idle).
PRISMA_SLOW_QUERY_THRESHOLD_MS=2000

# ── Auth (Better Auth) ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000
# Optional: comma-separated extra trusted origins (preview deploys, alt hostnames).
# BETTER_AUTH_URL is always trusted; this list is appended.
# Example: AUTH_TRUSTED_ORIGINS=https://preview.contractor-ops.com,https://staging.contractor-ops.com
AUTH_TRUSTED_ORIGINS=

# ── OAuth (Google) ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth (Microsoft) ──────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# Sender address for transactional emails (portal magic links, notifications)
EMAIL_FROM=noreply@contractor-ops.com
# Local dev: send app email to Mailpit (docker compose profile dev-tooling) instead of the Resend API.
# Requires NODE_ENV=development. RESEND_* stays required for schema / inbound webhooks.
# DEV_SMTP_HOST=127.0.0.1
# DEV_SMTP_PORT=1025

# ── Cloudflare R2 Storage ──────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=contractor-ops-documents
# Regional R2 buckets (per-org data residency)
R2_BUCKET_NAME_EU=contractor-ops-documents-eu
R2_BUCKET_NAME_ME=contractor-ops-documents-me
# Public URL for serving uploaded assets (e.g. organization logos)
R2_PUBLIC_URL=
# Local S3-compatible storage: docker compose profile dev-tooling (MinIO on localhost:9000).

# ── ClamAV Virus Scanner ──────────────────────────────────────────────────
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# ── Headless CMS (apps/cms — Payload v3 on blog.contractor-ops.io) ────────
# Dedicated Neon Postgres database, isolated from the multi-region app DBs.
# Provision a fresh Neon project ("contractor-ops-cms") and paste its connection
# string here — never reuse DATABASE_URL_* values.
CMS_DATABASE_URL=postgresql://user:pass@host/cmsdb?sslmode=require

# Payload session/encryption secret (>= 32 chars, random hex). Rotate by
# re-issuing every editor's login after a change.
PAYLOAD_SECRET=

# First-run bootstrap admin credentials consumed by `pnpm --filter
# @contractor-ops/cms seed:admin`. After the first run the seed script is a
# no-op; rotate the password in the Payload admin UI.
CMS_ADMIN_EMAIL=admin@example.com
CMS_ADMIN_PASSWORD=

# HMAC shared secret for the legal-documents revalidation webhook
# (apps/cms afterChange → apps/web /api/revalidate-legal). MUST be identical
# in both apps; rotate by deploying both sides together.
CMS_WEBHOOK_SECRET=

# Public origin for the CMS app — drives canonical URLs and OG image refs.
CMS_PUBLIC_URL=http://localhost:3002

# Origin of apps/web — apps/cms posts revalidation webhooks here. In Render
# private-network deploy use the internal hostport (e.g. http://web:3000).
WEB_APP_URL=http://localhost:3000

# ── Docker Compose — Infisical + dev tooling (optional, local only) ───────
# docker compose --profile infisical --profile dev-tooling up -d
# Link hub: http://localhost:8888 — Infisical (nginx): http://localhost:8090
# Mailpit :8025 — UI for captured mail; SMTP :1025 — set DEV_SMTP_HOST=127.0.0.1 + DEV_SMTP_PORT=1025
#   in this file so the Next.js app sends transactional email here (see Email section above).
# Infisical uses docker/infisical.env (SMTP_HOST=mailpit) separately.
# MinIO console :9001 (S3 API :9000), CloudBeaver :8978, Redis Insight :5540
# Port overrides: INFISICAL_HTTP_PORT, MAILPIT_UI_PORT, MAILPIT_SMTP_PORT, MINIO_API_PORT, MINIO_CONSOLE_PORT, CLOUDBEAVER_PORT, REDISINSIGHT_PORT, DEV_PORTAL_PORT
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# ── Slack Integration ──────────────────────────────────────────────────────
# Create app at api.slack.com/apps -> Basic Information -> App Credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Optional: override redirect URI (defaults to APP_URL/api/oauth/slack/callback)
SLACK_REDIRECT_URI=
# Encrypt Slack bot tokens at rest (AES-256-GCM). Generate with: openssl rand -hex 32
SLACK_TOKEN_ENCRYPTION_KEY=

# ── Linear Integration (OAuth) ────────────────────────────────────────────
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# ── Jira Integration (OAuth 2.0 3LO) ──────────────────────────────────────
# Create app at developer.atlassian.com -> OAuth 2.0 (3LO)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# ── DocuSign Integration ──────────────────────────────────────────────────
# Create app at developers.docusign.com
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_WEBHOOK_SECRET=

# ── Autenti Integration ──────────────────────────────────────────────────
AUTENTI_CLIENT_ID=
AUTENTI_CLIENT_SECRET=
AUTENTI_WEBHOOK_SECRET=

# ── Notion Integration ────────────────────────────────────────────────────
# Create integration at notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Confluence Integration (Atlassian OAuth 2.0 3LO) ─────────────────────
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=

# ── Google Calendar Integration ──────────────────────────────────────────
# Create OAuth credentials at console.cloud.google.com
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Google Workspace (Admin SDK Directory Import) ───────────────────────
# Requires domain-wide delegation with Admin SDK scopes
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=

# ── Outlook Calendar Integration (Microsoft Graph) ──────────────────────
# Adapter OAuth uses OUTLOOK_CLIENT_* (Microsoft app registration); keep in sync with integrations.
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=

# ── Secret Store (Integration Credentials + ZATCA Certificates) ─────────
# When configured, integration OAuth tokens and ZATCA certificates are stored
# in an external secret manager instead of in-memory. Without these vars, a
# non-persistent MemoryStore is used (fine for local dev).
# Self-hosted Infisical (docker compose --profile infisical): copy
# docker/infisical.env.example → docker/infisical.env; nginx serves UI on :8090 by default.
# INFISICAL_SITE_URL=http://localhost:8090
INFISICAL_SITE_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=production
# SDK auth-token TTL in milliseconds. Defaults to 1h. The store proactively
# re-logs in 60s before this expires (single-flighted) so a 401 never reaches
# a request handler. Lower it (e.g. 300000 = 5min) for testing rotation.
INFISICAL_TOKEN_TTL_MS=3600000

# ── Bank Account Encryption (AES-256-GCM) ───────────────────────────────
# Generate with: openssl rand -hex 32
BANK_ACCOUNT_ENCRYPTION_KEY=

# ── OCR Invoice Parsing (Claude Vision) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ── Upstash Redis (cache layer) ─────────────────────────────────────────
# Create a Redis database at console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Load testing (k6) — bypass /api/trpc rate limits when header matches ──
# Never set LOAD_TEST_BYPASS on public production. Blocked automatically when VERCEL_ENV=production.
# k6 sends: X-Load-Test-Secret: <same value as LOAD_TEST_SECRET>
LOAD_TEST_BYPASS=
LOAD_TEST_SECRET=

# ── Playwright perf (apps/web e2e/perf) ───────────────────────────────────
E2E_EMAIL=
E2E_PASSWORD=

# Optional integration smoke (apps/web `pnpm e2e:integration`) — e.g. Resend inbound route reachability
RUN_RESEND_E2E=
E2E_WEB_URL=http://127.0.0.1:3000

# ── Upstash QStash (webhook queue processing) ───────────────────────────
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Cron Jobs ────────────────────────────────────────────────────────────
# Vercel Cron secret (protects all /api/cron/* endpoints)
# Generate with: openssl rand -hex 32
CRON_SECRET=
# Same secret is required for tRPC mutation `exchangeRate.fetchDaily` (schedulers must send
#   Authorization: Bearer <CRON_SECRET>
# e.g. from a worker calling POST /api/trpc with the appropriate procedure payload and headers).

# ── Enterprise Public API ───────────────────────────────────────────────
# HMAC secret for API key hashing. Generate with: openssl rand -hex 32
API_KEY_HMAC_SECRET=
# Port for the public-api Hono server (default: 4100)
PUBLIC_API_PORT=4100

# ── Portal Subdomain Routing ────────────────────────────────────────────
# Base domain for portal subdomain routing: {slug}.{PORTAL_BASE_DOMAIN}
# Example: acme.portal.localhost:3000 or acme.portal.contractorops.com
PORTAL_BASE_DOMAIN=portal.localhost:3000

# ── Platform Operator Org (cross-tenant admin gate) ─────────────────────
# UUID of the dedicated org whose members hold the `platform_operator`
# role. Required in production: the admin shell at /admin/* refuses access
# unless the active session's organizationId matches this value AND the
# member's role is `platform_operator`. Leave unset locally to disable the
# admin surface. See F-SEC-04 in .audit-2026-05-03/02-security.md.
PLATFORM_OPERATOR_ORG_ID=

# ── Stripe Billing ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
NEXT_PUBLIC_STRIPE_PRICE_TOPUP_10=
NEXT_PUBLIC_STRIPE_PRICE_TOPUP_25=
NEXT_PUBLIC_STRIPE_PRICE_TOPUP_50=

# ── Microsoft Teams Integration (Phase 32) ─────────────────────────────────
# Azure Bot Service app credentials (register at portal.azure.com -> Bot Services)
AZURE_BOT_APP_ID=
AZURE_BOT_APP_SECRET=

# ── Observability (Sentry) ──────────────────────────────────────────────────
# Get DSN from https://sentry.io -> Project Settings -> Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source map uploads (generate at sentry.io/settings/auth-tokens)
SENTRY_AUTH_TOKEN=

# ── Observability (Axiom) ───────────────────────────────────────────────────
# Axiom log drain — connect via Vercel integration or set manually
# https://app.axiom.co -> Settings -> API Tokens
AXIOM_TOKEN=
AXIOM_DATASET=contractor-ops
# Send logs to Axiom in development (default: false)
AXIOM_DEV=false

# ── Observability (Logging) ─────────────────────────────────────────────────
# Log level override: trace | debug | info | warn | error | fatal
# Defaults to "debug" in development, "info" in production
LOG_LEVEL=

# ── Uptime & Cron Monitoring ───────────────────────────────────────────────
# Cronitor — cron job heartbeat monitoring (https://cronitor.io)
# API key from Dashboard → Settings → API Keys
# Create monitors named: reminders, token-refresh, trial-notifications, job-health
CRONITOR_API_KEY=
# UptimeRobot — external uptime monitoring (https://uptimerobot.com)
# Configure externally: HTTP(s) monitor → GET {NEXT_PUBLIC_APP_URL}/api/health
# Alert contacts: email, Slack webhook, or PagerDuty
# No env var needed — UptimeRobot pings your /api/health endpoint externally

# ── Render deployment (production only) ─────────────────────────────────────
# Set these on Render Dashboard, not here. Listed for documentation.
# - PORT=3000 (web service binds here; Render's private network blocks 10000)
# - HOSTNAME=0.0.0.0
# - WORKER_TARGET_HOSTPORT=web-XXXX:3000  (worker -> web on private network)
#   (wired automatically via render.yaml fromService; use WORKER_TARGET_URL locally)
# - NEXT_PUBLIC_APP_URL / APP_URL / BETTER_AUTH_URL must point to the public
#   custom domain bound in Render, e.g. https://app.contractor-ops.com
# - CLAMAV_HOST=clamav-XXXX  (private hostname of the clamav pserv)
# - SENTRY_AUTH_TOKEN must be set as a build-time env (sync: false in render.yaml).
# - API_KEY_HMAC_SECRET — Enterprise REST API (apps/public-api) uses this to
#   derive API-key hashes. Generate with: openssl rand -hex 32
# - PUBLIC_API_PORT=3000  (apps/public-api HTTP bind port; Render web service)

# ── Phase 57 — Government API clients (HMRC VAT + VIES USt-IdNr) ─────────────
# See .planning/phases/57-government-api-clients/57-CONTEXT.md (D-01, D-03).
# HMRC OAuth client credentials live in SecretStore; env below points to the path.
HMRC_ENV=sandbox                     # sandbox | production
VIES_ENV=production                  # sandbox | production (VIES has no formal sandbox; keep production)
HMRC_CLIENT_ID_SECRET_PATH=hmrc/client_id
HMRC_CLIENT_SECRET_SECRET_PATH=hmrc/client_secret
HMRC_PLATFORM_VRN=                   # platform's own VRN used as requesterVrn for HMRC verified lookups + VIES requesterNumber

# ── Feature Flags (self-hosted Unleash OSS, per region) ─────────────────────
# Two Unleash instances: one per data region (EU + ME). The server-side SDK
# inside apps/web and apps/public-api picks the instance matching the active
# org's dataRegion for every evaluation. The code-level jurisdiction constraint
# is enforced BEFORE the Unleash call, so an EU org can never resolve a
# `jurisdiction: 'ME'` flag to true regardless of what the dashboard says.
#
# Local dev: `docker compose --profile unleash up -d` boots a single Unleash
# server on http://localhost:4242. Point both UNLEASH_URL_EU and UNLEASH_URL_ME
# at it for dev — the jurisdiction short-circuit still works.
#
# API tokens: create "server-side" tokens in the Unleash UI (Admin → API
# access). Format: "<env>:<project>.<secret>" e.g. "default:development.abc123".
#
# Missing values = stub client: all flags fall back to code-declared defaults.
UNLEASH_URL_EU=http://localhost:4242/api/
UNLEASH_API_TOKEN_EU=
UNLEASH_URL_ME=http://localhost:4242/api/
UNLEASH_API_TOKEN_ME=
UNLEASH_APP_NAME=contractor-ops
UNLEASH_ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Phase 70 — Feature-flag signoff bypass (LOCAL-ONLY)
# ---------------------------------------------------------------------------
# When set to "local", the boot-time gate in
# packages/feature-flags/src/registry.ts emits a warn line INSTEAD of
# process.exit(1) when a gated-namespace flag (compliance-*,
# idp-deprovisioning, gulf-*, offboarding-ip-*) is missing from
# packages/feature-flags/src/signoff-registry-flags.json.
#
# Production environments MUST keep this empty. Documented in:
#   docs/lint-remediation/flag-signoff.md
FLAG_SIGNOFF_BYPASS=

# ── Trusted reverse-proxy CIDRs (F-SEC-17) ─────────────────────────────────
# Comma-separated CIDR ranges (or proxy-addr keywords: loopback, linklocal,
# uniquelocal) treated as trusted hops. The middleware walks X-Forwarded-For
# right-to-left and stops at the first untrusted hop — this is what prevents
# remote clients from spoofing their IP for rate-limit bypass.
#
# Render typical: "loopback,linklocal,uniquelocal" (the platform proxy is on
# the same node as the app). If you front Render with Cloudflare, switch to
# Cloudflare's IP ranges instead. See:
#   https://www.cloudflare.com/ips/
#
# Default when unset: "loopback,linklocal,uniquelocal" (safe for Render).
TRUSTED_PROXIES=

# ── Dev seed (packages/db/scripts/seed-dev.ts) ─────────────────────────────
# Shared dev password applied to every seeded user account. Hashed once via
# Better Auth's scrypt and reused across all Account.password rows. Safe to
# rotate per session — only used by `pnpm db:seed:dev`.
SEED_PASSWORD=Test1234!
# Optional regex of additional DB hostnames the seed will accept. The script
# refuses to run unless DATABASE_URL's host matches localhost / 127.0.0.1 /
# host.docker.internal / *.neon.tech (with a dev|local|staging marker), or
# matches this regex. Leave empty for default behaviour.
SEED_DEV_ALLOWED_HOST=

# ── Cloudflare Turnstile (F-SEC-22 — signup bot protection) ────────────────
# Create at https://dash.cloudflare.com/?to=/:account/turnstile (free tier).
# The site key is public; the secret key MUST stay server-side. In dev you
# can leave both empty and the signup verifier short-circuits to "ok"; in
# production the verifier fails-closed when TURNSTILE_SECRET_KEY is missing.
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Set the Turnstile secret in your secret manager (Infisical / Render env).
# Leave the value blank in this checked-in example so a repo grep never
# returns a real secret.
TURNSTILE_SECRET_KEY=

# ── Polish company-registry lookup (contractor wizard NIP autofill) ────────
# The contractor wizard's "Fetch from registry" button calls one of two
# providers behind a single adapter port:
#   - dataport — REST/JSON, free 10 req/day (no API key needed). Used in dev.
#   - bir1     — GUS BIR1 SOAP service (via the `bir1` npm package).
#                Requires a User Key from GUS and a whitelisted IP for prod.
# Default is `dataport`; flip to `bir1` once a GUS user key is provisioned.
COMPANY_REGISTRY_PROVIDER=dataport
# Optional dataport API key (paid tier). Leave blank to use the free tier
# limited to 10 lookups per day per IP.
DATAPORT_API_KEY=
# Optional override for the dataport base URL (defaults to https://dataport.pl).
DATAPORT_BASE_URL=
