# ── Core ─────────────────────────────────────────────────────────────────────
# Do NOT set NODE_ENV here — Next.js / Vitest / Playwright each set it to the
# correct value automatically. Pinning it to "development" in .env breaks
# `next build` (the App Router falls back to Pages-Router /_error + /404
# generators and emits the spurious "<Html> should not be imported outside of
# pages/_document" prerender error).
PUBLIC_APP_URL="http://localhost:3000"
# Used by server-side adapters (DocuSign, Linear, Jira) for OAuth redirects
APP_URL="http://localhost:3000"
# Fastify API origin (apps/api). Serves: OAuth redirect URIs + CORS allowlist,
# QStash callback destinations, apps/cms revalidate-legal webhook target,
# cron-worker outbound API calls. In Render private-network deploy use the
# internal hostport (e.g. http://api:4000).
API_URL="http://localhost:4000"

# ── Vite SPA (apps/web-vite) ─────────────────────────────────────────────────
# Build-time vars (baked into the static bundle). Must match the running API host.
VITE_APP_URL="http://localhost:3000"
VITE_API_URL="http://localhost:4000"
# Optional — browser error tracking for the Vite SPA (@sentry/react)
VITE_SENTRY_DSN=
# Optional — PostHog product analytics (mirrors NEXT_PUBLIC_POSTHOG_* on the SPA)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Optional — Cloudflare Turnstile site key for auth forms
VITE_TURNSTILE_SITE_KEY=
# Optional — admin SPA loader gate (mirrors PLATFORM_OPERATOR_ORG_ID for client checks)
VITE_PLATFORM_OPERATOR_ORG_ID=
# Optional — InPost GeoWidget public token (parcel-locker picker in equipment + portal returns)
VITE_INPOST_GEOWIDGET_TOKEN=
# Public URL the marketing site is reachable at; embedded in RSS feeds + OG
# meta. Defaults to https://contractor-ops.io if unset.
NEXT_PUBLIC_LANDING_URL="http://localhost:3001"

# Public URL of the headless CMS (apps/cms / Payload). Read by
# apps/landing/src/lib/cms.ts for the blog data layer. Defaults to
# https://blog.contractor-ops.io if unset.
NEXT_PUBLIC_CMS_URL="http://localhost:3002"

# ── 21st.dev MCP server (developer-side only) ────────────────────────────────
# Required to use the `21st-dev` MCP server defined in .mcp.json — fetches
# community components by description. Sign up at https://21st.dev. NOT
# required at runtime.
TWENTY_FIRST_API_KEY=

# Primary data region for legal PDFs / cross-border detection (EU | ME)
DATA_HOSTING_REGION="EU"

# ── Database (Neon | local Postgres) ─────────────────────────────────────────
# Prod / pre-prod / staging: Neon connection string (https://console.neon.tech).
# Local dev fast path: run `docker compose --profile dev-tooling up -d app-db`
# and use
#   DATABASE_URL=postgresql://app:app@localhost:5433/contractor_ops_eu
# App code talks via @prisma/adapter-pg (standard pg driver) so any Postgres 17
# works. Keep Neon for pre-prod to validate driver+latency behaviour.
DATABASE_URL=

# ── Multi-Region Database (Neon projects) ───────────────────────────────────
# Prod: separate Neon projects per region (different geographies).
# Local dev (one Postgres container, two databases — see docker-compose
# app-db + docker/postgres/10-create-me-db.sql):
#   DATABASE_URL_EU=postgresql://app:app@localhost:5433/contractor_ops_eu
#   DATABASE_URL_ME=postgresql://app:app@localhost:5433/contractor_ops_me
# After bringing app-db up, run `pnpm db:migrate:dev` (applies to whichever
# URL DATABASE_URL points at) then `pnpm db:migrate:all` to propagate to
# both region databases.
DATABASE_URL_EU=
DATABASE_URL_ME=
# FOUND7-03 — US region (us-east-1). OPTIONAL: leave unset locally. The app
# boots clean with no US DB; `getRegionalClient('US')` lazy-throws only on
# actual access. Set once a US Neon project is provisioned (Phase 83 US-INFRA).
DATABASE_URL_US=

# ── F-SCALE-06 — Read replicas (optional, opt-in per call site) ─────────────
# When set, call sites that call `readReplica(region, …)` (currently only
# `dashboard.kpis`) route their reads to the replica instead of the writer.
# Failures fall back to the writer with a Pino warn breadcrumb; 5+ failures
# in 60s open a circuit breaker for 30s. Mutations and `$transaction` always
# go to the writer regardless. Leave unset locally.
DATABASE_URL_EU_RO=
DATABASE_URL_ME_RO=
# US read-replica deferred (US-INFRA-01). Leave unset — getReplicaClient('US')
# falls back to the writer until a US replica is provisioned.
DATABASE_URL_US_RO=

# NEW-ARCH-01 — RLS bypass tripwire for `readReplica()`.
# Set to `true` once `CREATE POLICY` migrations are deployed; activates the
# tripwire in `readReplica()` (packages/db/src/replica.ts) so any call site
# that bypasses RLS scoping (raw PrismaClient, no `SET LOCAL app.org_id`)
# fails loudly instead of silently reading with NULL or being denied. Leave
# unset until policies actually exist in the schema. See
# .audit-2026-05-03/REVIEW-R3-ARCHITECTURE.md (NEW-ARCH-01).
RLS_POLICIES_ENFORCED=

# Slow-query warn threshold (ms). Default 200 is fine for native-protocol
# Postgres; raise it for Neon serverless HTTP (~100-150ms per-query overhead +
# scale-to-zero cold starts of 5-10s on the first query after idle).
PRISMA_SLOW_QUERY_THRESHOLD_MS=2000

# ── Auth (Better Auth) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3000"
# Optional: comma-separated extra trusted origins (preview deploys, alt hostnames).
# BETTER_AUTH_URL is always trusted; this list is appended.
# Example: AUTH_TRUSTED_ORIGINS=https://preview.contractor-ops.com,https://staging.contractor-ops.com
AUTH_TRUSTED_ORIGINS=

# ── OAuth (Google) ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth (Microsoft) ──────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# Sender address for transactional emails (portal magic links, notifications)
EMAIL_FROM="noreply@contractor-ops.com"
# Local dev: send app email to Mailpit (docker compose profile dev-tooling) instead of the Resend API.
# Requires NODE_ENV=development. RESEND_* stays required for schema / inbound webhooks.
DEV_SMTP_HOST="127.0.0.1"
DEV_SMTP_PORT=1025

# ── Cloudflare R2 Storage (S3-compatible) ──────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME="contractor-ops-documents"
# Regional R2 buckets (per-org data residency)
R2_BUCKET_NAME_EU="contractor-ops-documents-eu"
R2_BUCKET_NAME_ME="contractor-ops-documents-me"
# US region bucket — OPTIONAL, no default (lazy-throw on US-org file access)
R2_BUCKET_NAME_US=
# Public URL for serving uploaded assets (e.g. organization logos)
R2_PUBLIC_URL=
# Optional endpoint override (S3-compatible storage). Leave empty for real
# Cloudflare R2 (SDK derives the URL from R2_ACCOUNT_ID). Set to point at a
# local MinIO instance for offline dev:
#   R2_ENDPOINT=http://localhost:9000
#   R2_FORCE_PATH_STYLE=true
#   R2_ACCESS_KEY_ID=minioadmin
#   R2_SECRET_ACCESS_KEY=minioadmin
#   R2_ACCOUNT_ID=minio       # unused when R2_ENDPOINT is set, still required by schema
# Buckets must exist in MinIO before first request — `mc mb` or the console.
R2_ENDPOINT=
R2_FORCE_PATH_STYLE=

# ── ClamAV Virus Scanner ──────────────────────────────────────────────────
CLAMAV_HOST="127.0.0.1"
CLAMAV_PORT=3310

# ── Headless CMS (apps/cms — Payload v3 on blog.contractor-ops.io) ────────
# Dedicated Postgres database, isolated from the multi-region app DBs.
# Prod: provision a fresh Neon project ("contractor-ops-cms") — never reuse
# DATABASE_URL_* values.
# Local dev (app-db hosts it alongside the EU/ME twins — see
# docker/postgres/10-create-me-db.sql):
#   CMS_DATABASE_URL=postgresql://app:app@localhost:5433/contractor_ops_cms
CMS_DATABASE_URL=

# Payload session/encryption secret (>= 32 chars, random hex). Rotate by
# re-issuing every editor's login after a change.
PAYLOAD_SECRET=

# First-run bootstrap admin credentials consumed by `pnpm --filter
# @contractor-ops/cms seed:admin`. After the first run the seed script is a
# no-op; rotate the password in the Payload admin UI.
CMS_ADMIN_EMAIL=
CMS_ADMIN_PASSWORD=

# HMAC shared secret for the legal-documents revalidation webhook
# (apps/cms afterChange → apps/web /api/revalidate-legal). MUST be identical
# in both apps; rotate by deploying both sides together.
CMS_WEBHOOK_SECRET=

# Public origin for the CMS app — drives canonical URLs and OG image refs.
CMS_PUBLIC_URL="http://localhost:3002"

# ── Docker Compose — Infisical + dev tooling (optional, local only) ───────
# docker compose --profile infisical --profile dev-tooling up -d
# Link hub: http://localhost:8888 — Infisical (nginx): http://localhost:8090
# Mailpit :8025 — UI for captured mail; SMTP :1025 — set DEV_SMTP_HOST=127.0.0.1 + DEV_SMTP_PORT=1025
#   in this file so the Next.js app sends transactional email here (see Email section above).
# Infisical uses docker/infisical.env (SMTP_HOST=mailpit) separately.
# MinIO console :9001 (S3 API :9000), CloudBeaver :8978, Redis Insight :5540
# Port overrides: INFISICAL_HTTP_PORT, MAILPIT_UI_PORT, MAILPIT_SMTP_PORT, MINIO_API_PORT, MINIO_CONSOLE_PORT, DBGATE_PORT, REDISINSIGHT_PORT, DEV_PORTAL_PORT
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# ── Slack Integration ──────────────────────────────────────────────────────
# Create app at api.slack.com/apps -> Basic Information -> App Credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Encrypt Slack bot tokens at rest (AES-256-GCM). Generate with: openssl rand -hex 32
SLACK_TOKEN_ENCRYPTION_KEY=

# ── Linear Integration (OAuth) ────────────────────────────────────────────
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# ── Jira Integration (OAuth 2.0 3LO) ──────────────────────────────────────
# Create app at developer.atlassian.com -> OAuth 2.0 (3LO)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# ── DocuSign Integration ──────────────────────────────────────────────────
# Create app at developers.docusign.com
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_WEBHOOK_SECRET=

# ── Autenti Integration ──────────────────────────────────────────────────
AUTENTI_CLIENT_ID=
AUTENTI_CLIENT_SECRET=
AUTENTI_WEBHOOK_SECRET=

# ── Notion Integration ────────────────────────────────────────────────────
# Create integration at notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Confluence Integration (Atlassian OAuth 2.0 3LO) ─────────────────────
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=

# ── Google Calendar Integration ──────────────────────────────────────────
# Create OAuth credentials at console.cloud.google.com
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Google Workspace (Admin SDK Directory Import) ───────────────────────
# Requires domain-wide delegation with Admin SDK scopes
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=

# ── Outlook Calendar Integration (Microsoft Graph) ──────────────────────
# Adapter OAuth uses OUTLOOK_CLIENT_* (Microsoft app registration); keep in sync with integrations.
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=

# ── Secret Store (Integration Credentials + ZATCA Certificates) ─────────
# When configured, integration OAuth tokens and ZATCA certificates are stored
# in an external secret manager instead of in-memory. Without these vars, a
# non-persistent MemoryStore is used (fine for local dev).
# Self-hosted Infisical (docker compose --profile infisical): copy
# docker/infisical.env.example → docker/infisical.env; nginx serves UI on :8090 by default.
# INFISICAL_SITE_URL=http://localhost:8090
INFISICAL_SITE_URL=
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=
# SDK auth-token TTL in milliseconds. Defaults to 1h. The store proactively
# re-logs in 60s before this expires (single-flighted) so a 401 never reaches
# a request handler. Lower it (e.g. 300000 = 5min) for testing rotation.
INFISICAL_TOKEN_TTL_MS=3600000

# ── Bank Account Encryption (AES-256-GCM) ───────────────────────────────
# Generate with: openssl rand -hex 32
BANK_ACCOUNT_ENCRYPTION_KEY=

# ── SSN Encryption (AES-256-GCM, Phase 84 — US-FIELD-02) ─────────────────
# Dedicated key, separate from the bank key (independent blast radius, D-01).
# Required: the SSN write path fails loud at boot if unset. Generate your own
# with: openssl rand -hex 32.
SSN_ENCRYPTION_KEY=

# ── Employee PII Encryption (AES-256-GCM) ────────────────────────────────
# Dedicated key for the non-SSN employee national IDs (PESEL, Iqama, Emirates
# ID), separate from the SSN and bank keys so each data class has an
# independent blast radius. The US SSN column keeps using SSN_ENCRYPTION_KEY.
# Required: the employee national-ID write path fails loud at boot if unset.
# Generate your own with: openssl rand -hex 32.
EMPLOYEE_PII_ENCRYPTION_KEY=

# ── USPS Address Validation (Phase 84 — US-FIELD-03, optional) ───────────
# OAuth2 client-credentials for the USPS Addresses 3.0 CASS API. Optional:
# LOCAL-ONLY has no live creds; the address client fails-open (unverified flag)
# when absent. Obtain at developers.usps.com.
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

# ── OCR Invoice Parsing (Claude Vision) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ── Upstash Redis (cache layer) ─────────────────────────────────────────
# Prod: create a Redis database at console.upstash.com.
# Local dev: run `docker compose --profile dev-tooling up -d` and use
#   UPSTASH_REDIS_REST_URL=http://localhost:8079
#   UPSTASH_REDIS_REST_TOKEN=example_token
# (SRH proxy fronts a plain Redis container — see docker-compose.yml).
# Also backs the public-API per-tier MONTHLY request quota (enforceApiTierQuota):
# REQUIRED in prod for a correct global count; unset falls back to a per-instance
# in-memory counter (non-prod best-effort only).
UPSTASH_REDIS_REST_URL="http://localhost:8079"
UPSTASH_REDIS_REST_TOKEN="example_token"

# ── Load testing (k6) — bypass /api/trpc rate limits when header matches ──
# Never set LOAD_TEST_BYPASS on public production. Blocked automatically when VERCEL_ENV=production.
# k6 sends: X-Load-Test-Secret: <same value as LOAD_TEST_SECRET>
LOAD_TEST_BYPASS=
LOAD_TEST_SECRET=

# ── Playwright / E2E (apps/web) ────────────────────────────────────────────
E2E_EMAIL=
E2E_PASSWORD=
# Playwright resolves relative URLs via this origin when exercising packaged configs (mirror CI defaults).
PLAYWRIGHT_BASE_URL="http://localhost:3000"

# ── QA walk-and-fix fixtures ────────────────────────────────────────────────
# Real values populated by `pnpm seed:qa` inside the
# `=== QA walk fixtures ===` marker block further down the file.

# Optional integration smoke (apps/web `pnpm e2e:integration`) — e.g. Resend inbound route reachability
RUN_RESEND_E2E=
E2E_WEB_URL="http://127.0.0.1:3000"

# ── Upstash QStash (webhook queue processing) ───────────────────────────
# Prod: create at console.upstash.com → QStash.
# Local dev: run `docker compose --profile dev-tooling up -d qstash-dev` and
# copy the token + signing keys printed on container startup into the three
# vars below, plus set QSTASH_URL (next block) to point at the dev server.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# QStash REST endpoint. Leave empty in production (SDK defaults to
# https://qstash.upstash.io). For local dev set to the dev server URL:
#   QSTASH_URL=http://localhost:8089
# NOTE: PUBLIC_APP_URL must be reachable from inside the qstash-dev
# container — use http://host.docker.internal:3000 when Next.js runs on
# the host.
QSTASH_URL=

# ── Cron Jobs ────────────────────────────────────────────────────────────
# Vercel Cron secret (protects all /api/cron/* endpoints)
# Generate with: openssl rand -hex 32
CRON_SECRET=
# Same secret is required for tRPC mutation `exchangeRate.fetchDaily` (schedulers must send
#   Authorization: Bearer <CRON_SECRET>
# e.g. from a worker calling POST /api/trpc with the appropriate procedure payload and headers).
#
# cron-worker schedule overrides (defaults live in apps/cron-worker/src/env.ts).
# Informational 1099-K threshold tracker — daily band scan; ships dark behind
# module.us-expansion and never files a 1099-K. Default: 05:00 UTC daily.
# CRON_FORM_1099K_TRACKER_SCHEDULE=0 5 * * *
# Year-end 1099-NEC batch-due reminder — notify-only (never generates or files);
# ships dark behind module.us-expansion. Default: mid-January (08:00 UTC, Jan 15),
# ahead of the ~Jan 31 furnish deadline.
# CRON_YEAR_END_1099_REMINDER_SCHEDULE=0 8 15 1 *

# ── Enterprise Public API ───────────────────────────────────────────────
# HMAC secret for API key hashing. Generate with: openssl rand -hex 32
API_KEY_HMAC_SECRET=
# Port for the public-api Hono server (default: 4100)
PUBLIC_API_PORT=4100
# Port for the cron-worker internal health endpoint. MUST differ from
# PUBLIC_API_PORT (default: 4101).
# CRON_HEALTH_PORT=4101

# ── Portal Subdomain Routing ────────────────────────────────────────────
# Base domain for portal subdomain routing: {slug}.{PORTAL_BASE_DOMAIN}
# Example: acme.portal.localhost:3000 or acme.portal.contractorops.com
PORTAL_BASE_DOMAIN="portal.localhost:3000"

# ── Platform Operator Org (cross-tenant admin gate) ─────────────────────
# UUID of the dedicated org whose members hold the `platform_operator`
# role. Required in production: the admin shell at /admin/* refuses access
# unless the active session's organizationId matches this value AND the
# member's role is `platform_operator`. Leave unset locally to disable the
# admin surface. See F-SEC-04 in .audit-2026-05-03/02-security.md.
PLATFORM_OPERATOR_ORG_ID=

# ── Demo read-only mode ─────────────────────────────────────────────────
# Blocks every tRPC mutation (queries still pass) and skips all real org
# outbound (KSeF/ZATCA/Peppol/HMRC, email, webhooks) for demo contexts.
# Env-controlled ONLY — never inferred from metadata.profile.
#
#   DEMO_MODE=true        → the whole deployment is read-only (every org).
#                           Set this on a dedicated demo deploy.
#   DEMO_ORG_IDS=id1,id2  → only those org IDs are read-only on a shared
#                           deployment (comma-separated; trimmed).
#
# Set DEMO_ORG_IDS in the demo deployment env (and/or DEMO_MODE=true for a
# fully dedicated demo deploy). No ad-hoc Render service change without ask.
DEMO_MODE=
DEMO_ORG_IDS=

# ── Stripe Billing ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Storecove (Peppol BIS) webhook HMAC secret. Deployment-scoped (no per-tenant
# signing material); empty in dev → adapter refuses to register and the
# /webhooks/storecove route returns 500 "Not configured".
STORECOVE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_TOPUP_10=
STRIPE_PRICE_TOPUP_25=
STRIPE_PRICE_TOPUP_50=

# ── Stripe (web-vite) ───────────────────────────────────────────────────
# Vite only inlines `VITE_*` via `import.meta.env`; the `NEXT_PUBLIC_*`
# keys above are consumed by apps/web (Next.js) only. apps/web-vite reads
# the keys below in plan-comparison-grid.tsx + use-billing.ts top-up
# checkout. Must be present BEFORE `pnpm --filter @contractor-ops/web-vite
# build` runs for each environment. Same Stripe Price IDs as above.
VITE_STRIPE_PRICE_STARTER=
VITE_STRIPE_PRICE_PRO=
VITE_STRIPE_PRICE_ENTERPRISE=
VITE_STRIPE_PRICE_TOPUP_10=
VITE_STRIPE_PRICE_TOPUP_25=
VITE_STRIPE_PRICE_TOPUP_50=

# ── PostHog (product analytics) ─────────────────────────────────────────
# Server-side captures from packages/api use POSTHOG_API_KEY; landing +
# web client posthog-js uses NEXT_PUBLIC_POSTHOG_KEY. Host defaults to
# the EU cloud (data residency); override for self-hosted.
POSTHOG_API_KEY=
POSTHOG_HOST="https://eu.i.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ── Microsoft Teams Integration (Phase 32) ─────────────────────────────────
# Azure Bot Service app credentials (register at portal.azure.com -> Bot Services)
AZURE_BOT_APP_ID=
AZURE_BOT_APP_SECRET=

# InPost ShipX webhook — set to "true" to reject unsigned webhook payloads in
# EVERY environment (disables the dev/staging shipment-id payload fallback).
# Production already rejects unsigned; use this to make staging mirror prod.
STRICT_INPOST_SIGNATURE=

# ── Observability (Sentry | GlitchTip) ──────────────────────────────────────
# Prod: get DSN from https://sentry.io -> Project Settings -> Client Keys.
# Local dev: run `docker compose --profile glitchtip up -d`, register the
# first user at http://localhost:8000 (they become admin), create an org +
# project, then paste the printed DSN below. GlitchTip is Sentry-protocol
# compatible — @sentry/nextjs ships events without code changes.
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source map uploads (generate at sentry.io/settings/auth-tokens)
SENTRY_AUTH_TOKEN=

# ── Observability (Axiom) ───────────────────────────────────────────────────
# Axiom log drain — connect via Vercel integration or set manually
# https://app.axiom.co -> Settings -> API Tokens. Production sink for Pino.
AXIOM_TOKEN=
AXIOM_DATASET=
# Send logs to Axiom in development (default: false). Leave OFF in dev so
# local runs do not burn the prod Axiom dataset's field quota.
AXIOM_DEV=

# ── Observability (Dev — Loki + GlitchTip) ─────────────────────────────────
# Local replacement for Axiom + Sentry SaaS in dev. Bring the stack up via
# `pnpm dev:observability` then paste the GlitchTip DSN into SENTRY_DSN /
# VITE_SENTRY_DSN above. Prod must leave these unset.
#
# LOKI_URL — when set, the root Pino logger adds a parallel stream that
# pushes to `${LOKI_URL}/loki/api/v1/push`. Default dev URL below.
LOKI_URL=
LOKI_SERVICE_LABEL=
# SENTRY_DEV=true defeats the dev hard-disable on every backend Sentry
# init (apps/api / apps/cron-worker / apps/public-api / apps/web-vite),
# so events flow into the local GlitchTip project. Leave empty in prod.
SENTRY_DEV=

# ── Observability (Logging) ─────────────────────────────────────────────────
# Log level override: trace | debug | info | warn | error | fatal
# Defaults to "debug" in development, "info" in production
LOG_LEVEL=

# ── Uptime & Cron Monitoring ───────────────────────────────────────────────
# Cronitor — cron job heartbeat monitoring (https://cronitor.io)
# API key from Dashboard → Settings → API Keys
# Create monitors named: reminders, token-refresh, trial-notifications, job-health
CRONITOR_API_KEY=
# UptimeRobot — external uptime monitoring (https://uptimerobot.com)
# Configure externally: HTTP(s) monitor → GET {PUBLIC_APP_URL}/api/health
# Alert contacts: email, Slack webhook, or PagerDuty
# No env var needed — UptimeRobot pings your /api/health endpoint externally

# ── Render deployment (production only) ─────────────────────────────────────
# Set these on Render Dashboard, not here. Listed for documentation.
# - PORT=3000 (web service binds here; Render's private network blocks 10000)
# - HOSTNAME=0.0.0.0
# - WORKER_TARGET_HOSTPORT=web-XXXX:3000  (worker -> web on private network)
#   (wired automatically via render.yaml fromService; use WORKER_TARGET_URL locally)
# - PUBLIC_APP_URL / APP_URL / BETTER_AUTH_URL must point to the public
#   custom domain bound in Render, e.g. https://app.contractor-ops.com
# - CLAMAV_HOST=clamav-XXXX  (private hostname of the clamav pserv)
# - SENTRY_AUTH_TOKEN must be set as a build-time env (sync: false in render.yaml).
# - API_KEY_HMAC_SECRET — Enterprise REST API (apps/public-api) uses this to
#   derive API-key hashes. Generate with: openssl rand -hex 32
# - PUBLIC_API_PORT=3000  (apps/public-api HTTP bind port; Render web service)

# ── Phase 57 — Government API clients (HMRC VAT + VIES USt-IdNr) ─────────────
# See .planning/phases/57-government-api-clients/57-CONTEXT.md (D-01, D-03).
# HMRC OAuth client credentials live in SecretStore; env below points to the path.
HMRC_ENV="sandbox"                     # sandbox | production
VIES_ENV="production"                  # sandbox | production (VIES has no formal sandbox; keep production)
HMRC_CLIENT_ID_SECRET_PATH="hmrc/client_id"
HMRC_CLIENT_SECRET_SECRET_PATH="hmrc/client_secret"
HMRC_PLATFORM_VRN=                   # platform's own VRN used as requesterVrn for HMRC verified lookups + VIES requesterNumber

# ── Feature Flags (self-hosted Unleash OSS, per region) ─────────────────────
# Two Unleash instances: one per data region (EU + ME). The server-side SDK
# inside apps/web and apps/public-api picks the instance matching the active
# org's dataRegion for every evaluation. The code-level jurisdiction constraint
# is enforced BEFORE the Unleash call, so an EU org can never resolve a
# `jurisdiction: 'ME'` flag to true regardless of what the dashboard says.
#
# Local dev: `docker compose --profile unleash up -d` boots a single Unleash
# server on http://localhost:4242. Point both UNLEASH_URL_EU and UNLEASH_URL_ME
# at it for dev — the jurisdiction short-circuit still works.
#
# API tokens: create "server-side" tokens in the Unleash UI (Admin → API
# access). Format: "<env>:<project>.<secret>" e.g. "default:development.abc123".
#
# Missing values = stub client: all flags fall back to code-declared defaults.
UNLEASH_URL_EU="http://localhost:4242/api/"
UNLEASH_API_TOKEN_EU=
UNLEASH_URL_ME="http://localhost:4242/api/"
UNLEASH_API_TOKEN_ME=
UNLEASH_APP_NAME="contractor-ops"
UNLEASH_ENVIRONMENT="development"

# ---------------------------------------------------------------------------
# Phase 70 — Feature-flag signoff bypass (LOCAL-ONLY)
# ---------------------------------------------------------------------------
# When set to "local", the boot-time gate in
# packages/feature-flags/src/registry.ts emits a warn line INSTEAD of
# process.exit(1) when a gated-namespace flag (compliance-*,
# idp-deprovisioning, gulf-*, offboarding-ip-*) is missing from
# packages/feature-flags/src/signoff-registry-flags.json.
#
# Production environments MUST keep this empty. Documented in:
#   docs/lint-remediation/flag-signoff.md
FLAG_SIGNOFF_BYPASS=

# ── Trusted reverse-proxy CIDRs (F-SEC-17) ─────────────────────────────────
# Comma-separated CIDR ranges (or proxy-addr keywords: loopback, linklocal,
# uniquelocal) treated as trusted hops. The middleware walks X-Forwarded-For
# right-to-left and stops at the first untrusted hop — this is what prevents
# remote clients from spoofing their IP for rate-limit bypass.
#
# Render typical: "loopback,linklocal,uniquelocal" (the platform proxy is on
# the same node as the app). If you front Render with Cloudflare, switch to
# Cloudflare's IP ranges instead. See:
#   https://www.cloudflare.com/ips/
#
# Default when unset: "loopback,linklocal,uniquelocal" (safe for Render).
TRUSTED_PROXIES=

# ── Dev seed (packages/db/scripts/seed-dev.ts) ─────────────────────────────
# Shared dev password applied to every seeded user account. Hashed once via
# Better Auth's scrypt and reused across all Account.password rows. Safe to
# rotate per session — only used by `pnpm db:seed:dev`.
SEED_PASSWORD=
# Optional regex of additional DB hostnames the seed will accept. The script
# refuses to run unless DATABASE_URL's host matches localhost / 127.0.0.1 /
# host.docker.internal / *.neon.tech (with a dev|local|staging marker), or
# matches this regex. Leave empty for default behaviour.
SEED_DEV_ALLOWED_HOST=

# ── Cloudflare Turnstile (F-SEC-22 — signup bot protection) ────────────────
# Create at https://dash.cloudflare.com/?to=/:account/turnstile (free tier).
# The SPA inlines VITE_TURNSTILE_SITE_KEY at build time; the server reads
# TURNSTILE_SECRET_KEY to verify tokens server-side. In dev both can be empty
# and the signup verifier short-circuits to "ok"; in production the verifier
# fails-closed when TURNSTILE_SECRET_KEY is missing.
# Set the secret in your secret manager (Infisical / Render env).
TURNSTILE_SECRET_KEY=

# ── Polish company-registry lookup (contractor wizard NIP autofill) ────────
# The contractor wizard's "Fetch from registry" button calls one of two
# providers behind a single adapter port:
#   - dataport — REST/JSON, free 10 req/day (no API key needed). Used in dev.
#   - bir1     — GUS BIR1 SOAP service (via the `bir1` npm package).
#                Requires a User Key from GUS and a whitelisted IP for prod.
# Default is `dataport`; flip to `bir1` once a GUS user key is provisioned.
COMPANY_REGISTRY_PROVIDER="dataport"
# Optional dataport API key (paid tier). Leave blank to use the free tier
# limited to 10 lookups per day per IP.
DATAPORT_API_KEY=
# Optional override for the dataport base URL (defaults to https://dataport.pl).
DATAPORT_BASE_URL="https://dataport.pl/"

# ── /api/health canary + pool tuning ──────────────────────────────────────
# Object key in R2 used by the health-check canary probe. The healthcheck
# does a HEAD; create an empty object at this path in each regional bucket
# before first deploy. Default: "_health/canary.txt".
R2_HEALTHCHECK_KEY=
# Prisma pg-pool connection cap (packages/db/src/client.ts). Default 10 is
# safe on Neon pooler. Raise only when scaling horizontally past 6 instances
# — Neon enforces a per-project pool ceiling (~60 active connections).
PG_POOL_MAX=
# Max tRPC request body size in MB (apps/web/.../api/trpc/[trpc]/route.ts).
# Default: 1. Raise selectively only if a procedure legitimately needs more.
TRPC_MAX_BODY_MB=
# Optional canary URL for QStash reachability check in the /api/health
# probe. Defaults to https://qstash.upstash.io when unset.
QSTASH_HEALTH_URL=
# Fastify CSP rollout knob (apps/api/src/plugins/helmet.ts). `report-only`
# emits Content-Security-Policy-Report-Only during the 48 h soak; any other
# value (or unset) enforces. Flip to `enforce` once report ingestion is clean.
CSP_MODE=

# ── Public REST API CORS ──────────────────────────────────────────────────
# Comma-separated additional origins allowed by apps/public-api CORS.
# Default cors() allows reflective Origin — set this in production to lock
# down which third-party browsers may call the API.
PUBLIC_API_CORS_ORIGINS=
# NOTE: ENABLE_API_DOCS + SCALAR_SRI_HASH were removed — the docs page is now
# served by the vendored `@scalar/hono-api-reference` npm dep (no CDN/SRI). If
# these are still set on the Render dashboard (sync:false) for the public-api
# service, drop them there too — they are unused.

# ── OCR + e-signature overrides ──────────────────────────────────────────
# Claude model used by the OCR adapter
# (packages/integrations/src/adapters/claude-ocr-adapter.ts). Default:
# "claude-sonnet-4-6". Switch to a faster/cheaper Haiku model for cost
# tuning, or pin a specific dated snapshot for reproducibility.
CLAUDE_OCR_MODEL_ID=
# DocuSign OAuth host — required in production to override the default
# sandbox host (account-d.docusign.com). Set to "account.docusign.com" for
# DocuSign production environments.
DOCUSIGN_OAUTH_HOST=
# Embedded recipient view URL TTL in seconds for DocuSign signing sessions
# (packages/integrations/src/adapters/docusign-adapter.ts). Default is the
# DocuSign API default (~5 min). Lower for stricter session windows.
DOCUSIGN_EMBEDDED_URL_TTL_SECONDS=

# Advisory-lock single-arg → two-arg transition shim.
# Set to `true` for the deploy that ships commit ce8b26f4 (and the next ONE
# deploy cycle after) so post-refactor callers also acquire the legacy
# single-arg lock — pre-refactor in-flight holders then serialize correctly.
# Unset (or set to anything else) once every instance has rolled to the new
# code; the shim adds one extra Postgres round-trip per lock acquisition.
# Remove the env var AND the shim code in packages/api/src/lib/advisory-lock.ts
# (search for TODO(advisory-lock-transition)) once the transition is over.
ADVISORY_LOCK_TRANSITION_DUAL_HOLD=

# ── KSeF Integration ───────────────────────────────────────────────────────
# Polish KSeF (Krajowy System e-Faktur) — tax-authority e-invoice system.
# Use the test endpoint until production credentials are issued by MF.
KSEF_BASE_URL="https://api-test.ksef.mf.gov.pl/v2"
KSEF_DATE_FROM=
KSEF_DATE_TO=
KSEF_PROD_TOKEN=
KSEF_TOKEN=
KSEF_NIP=
KSEF_DEBUG=

# ── QA walk overrides (added by /goal qa-walk-and-fix) ───────────────────
# Origins the walk orchestrator targets. Defaults match the standard local
# dev ports — only override when running the walk against a non-default
# deploy (preview/staging).
QA_WALK_WEB_URL=http://localhost:3000
QA_WALK_LANDING_URL=http://localhost:3001
QA_WALK_CMS_URL=http://localhost:3002

# === QA walk fixtures (auto-generated by seed-dev --profile=qa) ===
QA_ADMIN_EMAIL=
QA_ADMIN_PASSWORD=
QA_ACCOUNTANT_EMAIL=
QA_ACCOUNTANT_PASSWORD=
QA_CONTRACTOR_EMAIL=
QA_CONTRACTOR_PASSWORD=
QA_CONTRACTOR_PORTAL_TOKEN=
QA_DEFAULT_ORG_ID=
QA_EMPTY_ORG_ID=
QA_STRESS_ORG_ID=
# Force-enable dark-shipped flags so the QA walk renders classification/etc UI.
# Dev-only (evaluator hard-gates on NODE_ENV !== 'development').
QA_FORCE_FLAGS=
# === /QA walk fixtures ===
