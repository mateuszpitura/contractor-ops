# Database (Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Auth (Better Auth)
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth (Microsoft)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Resend - Email intake for invoice processing
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=contractor-ops-documents

# ClamAV Virus Scanner
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# Slack Integration
# Create app at api.slack.com/apps -> Basic Information -> App Credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Generate with: openssl rand -hex 32
SLACK_TOKEN_ENCRYPTION_KEY=

# Integration Framework (Phase 12)
# Per-provider encryption keys (32-byte hex, generate with: openssl rand -hex 32)
SLACK_ENCRYPTION_KEY=
# JIRA_ENCRYPTION_KEY=          # Uncomment when Jira integration is configured
# DOCUSIGN_ENCRYPTION_KEY=      # Uncomment when DocuSign integration is configured
# AUTENTI_ENCRYPTION_KEY=       # Uncomment when Autenti integration is configured
# KSEF_ENCRYPTION_KEY=          # Uncomment when KSeF integration is configured

# Upstash QStash (webhook queue processing)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Cron Jobs
# Vercel Cron secret (token refresh endpoint protection)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
