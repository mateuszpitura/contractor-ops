# Database (Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Auth (Better Auth)
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth (Microsoft)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Resend - Email intake for invoice processing
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=contractor-ops-documents

# ClamAV Virus Scanner
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# Slack Integration
# Create app at api.slack.com/apps -> Basic Information -> App Credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Generate with: openssl rand -hex 32
SLACK_TOKEN_ENCRYPTION_KEY=

# Integration Framework
# Per-provider encryption keys (32-byte hex, generate with: openssl rand -hex 32)
SLACK_ENCRYPTION_KEY=
JIRA_ENCRYPTION_KEY=
DOCUSIGN_ENCRYPTION_KEY=
AUTENTI_ENCRYPTION_KEY=
KSEF_ENCRYPTION_KEY=
NOTION_ENCRYPTION_KEY=
CONFLUENCE_ENCRYPTION_KEY=
GOOGLE_CALENDAR_ENCRYPTION_KEY=
OUTLOOK_CALENDAR_ENCRYPTION_KEY=
CLOCKIFY_ENCRYPTION_KEY=

# Linear Integration (OAuth)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_ENCRYPTION_KEY=
LINEAR_WEBHOOK_SECRET=

# Jira Integration (OAuth 2.0 3LO)
# Create app at developer.atlassian.com -> OAuth 2.0 (3LO)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# DocuSign Integration
# Create app at developers.docusign.com
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_WEBHOOK_SECRET=

# Autenti Integration
AUTENTI_CLIENT_ID=
AUTENTI_CLIENT_SECRET=
AUTENTI_WEBHOOK_SECRET=

# Notion Integration
# Create integration at notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Confluence Integration (Atlassian OAuth 2.0 3LO)
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=

# Google Calendar Integration
# Create OAuth credentials at console.cloud.google.com
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Outlook Calendar Integration (Microsoft Graph)
OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=

# Bank Account Encryption (AES-256-GCM)
# Generate with: openssl rand -hex 32
BANK_ACCOUNT_ENCRYPTION_KEY=

# OCR Invoice Parsing (Claude Vision)
ANTHROPIC_API_KEY=

# Upstash QStash (webhook queue processing)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Cron Jobs
# Vercel Cron secret (token refresh endpoint protection)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Portal Subdomain Routing (Phase 14)
# Base domain for portal subdomain routing: {slug}.{PORTAL_BASE_DOMAIN}
# Example: acme.portal.localhost:3000 or acme.portal.contractorops.com
PORTAL_BASE_DOMAIN=portal.localhost:3000

# Stripe Billing
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
