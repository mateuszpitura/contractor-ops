# Self-hosted Infisical (Docker Compose profile `infisical`).
# Copy to docker/infisical.env and replace ALL placeholder secrets before first boot.
# Generate values:
#   ENCRYPTION_KEY: openssl rand -hex 16
#   AUTH_SECRET: openssl rand -base64 32
# Public URL must match the nginx gateway (not the backend container directly):
# default is http://localhost:8090 — if you change INFISICAL_HTTP_PORT, update SITE_URL to match.
#
# Full variable reference: https://infisical.com/docs/self-hosting/configuration/envars

# Keys (required). Samples below match Infisical upstream .env.example — replace before any shared or production use.
#   ENCRYPTION_KEY: openssl rand -hex 16
#   AUTH_SECRET: openssl rand -base64 32
ENCRYPTION_KEY=71d4272ab295558b27312db1e9b16127
AUTH_SECRET=qGLZp5Lb62tuPLbm6dnHukd6sQSlbGGjpVSYXU4eZGI=

# Postgres (must match infisical-db service)
POSTGRES_PASSWORD=infisical
POSTGRES_USER=infisical
POSTGRES_DB=infisical
DB_CONNECTION_URI=postgres://infisical:infisical@infisical-db:5432/infisical

# Redis (must match infisical-redis hostname)
REDIS_URL=redis://infisical-redis:6379

# Public URL (must match how you open the UI; default compose maps 8090 → 8080)
SITE_URL=http://localhost:8090

# Mail / SMTP (optional locally; required for invites and password reset)
# With Docker profile `dev-tooling` (Mailpit), use plain SMTP — same Docker network as Infisical:
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_FROM_ADDRESS=dev@localhost
# SMTP_FROM_NAME=Infisical Dev
# (leave SMTP_USERNAME / SMTP_PASSWORD empty). Web UI: http://localhost:8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM_ADDRESS=dev@localhost
SMTP_FROM_NAME=Infisical Dev
SMTP_USERNAME=
SMTP_PASSWORD=

# CICD Integration
CLIENT_ID_GITHUB=
CLIENT_ID_GITHUB_APP=
CLIENT_SLUG_GITHUB_APP=
CLIENT_SECRET_GITHUB=
CLIENT_SECRET_GITHUB_APP=
CLIENT_ID_GITLAB=
CLIENT_SECRET_GITLAB=
CLIENT_PRIVATE_KEY_GITHUB_APP=
CLIENT_APP_ID_GITHUB_APP=

# Sentry (optional)
SENTRY_DSN=

# Infisical Cloud-only (ignore for self-hosted)
POSTHOG_HOST=
POSTHOG_PROJECT_API_KEY=

# SSO (optional)
CLIENT_ID_GOOGLE_LOGIN=
CLIENT_SECRET_GOOGLE_LOGIN=
CLIENT_ID_GITHUB_LOGIN=
CLIENT_SECRET_GITHUB_LOGIN=
CLIENT_ID_GITLAB_LOGIN=
CLIENT_SECRET_GITLAB_LOGIN=
CAPTCHA_SECRET=
NEXT_PUBLIC_CAPTCHA_SITE_KEY=

OTEL_TELEMETRY_COLLECTION_ENABLED=false
OTEL_EXPORT_TYPE=prometheus
OTEL_EXPORT_OTLP_ENDPOINT=
OTEL_OTLP_PUSH_INTERVAL=
OTEL_COLLECTOR_BASIC_AUTH_USERNAME=
OTEL_COLLECTOR_BASIC_AUTH_PASSWORD=

PLAIN_API_KEY=
PLAIN_WISH_LABEL_IDS=
SSL_CLIENT_CERTIFICATE_HEADER_KEY=

ENABLE_MSSQL_SECRET_ROTATION_ENCRYPT=true
